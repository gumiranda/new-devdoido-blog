---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/devdoido/PageShell.astro';
import ArticleCard from '../../components/devdoido/ArticleCard.astro';
import AsciiRule from '../../components/devdoido/AsciiRule.astro';
import Terminal from '../../components/devdoido/Terminal.astro';
import { SITE } from '../../data/devdoido';

export const prerender = true;

const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:3000';

interface Article {
  id: string;
  title: string;
  subtitle?: string;
  slug: string;
  excerpt?: string;
  coverUrl?: string;
  category?: string;
  publishedAt?: string;
  updatedAt?: string;
  views: number;
  contentHtml?: string;
  metaTitle?: string;
  metaDescription?: string;
  ogImageUrl?: string;
  twitterCard?: string;
  answerBox?: string;
  schemaJson?: any;
  faqJson?: any;
  tags?: { id: string; name: string; slug: string }[];
  workspaceId: string;
  moderationStatus?: string;
}

let allArticles: Article[] = [];

export async function getStaticPaths() {
  try {
    const resp = await fetch(`${API_BASE}/api/v1/public/articles?workspace=devdoido&perPage=200`);
    const data = await resp.json();
    allArticles = Array.isArray(data) ? data : [];
  } catch {
    allArticles = [];
  }
  return allArticles.map((a) => ({ params: { slug: a.slug }, props: { slug: a.slug } }));
}

const { slug } = Astro.params;

// The list endpoint above carries only summary fields. Fetch the single public
// endpoint to get the body, custom schema, FAQ and tags for this article.
let full: Article | undefined;
try {
  const r = await fetch(`${API_BASE}/api/v1/public/articles/devdoido/${slug}`);
  if (r.ok) full = await r.json();
} catch {
  /* API offline at build time */
}
const resolved = full ?? allArticles.find((a) => a.slug === slug);
if (!resolved) {
  return Astro.redirect('/404');
}
const post = resolved;

const relatedArticles = allArticles
  .filter((a) => a.slug !== post.slug && a.category === post.category)
  .slice(0, 3);

const coverColors = ['a', 'b', 'c'];
const articleSection = post.category ?? 'Blog';
const postTags = post.tags?.map((t) => t.slug) ?? [];
const pubDate = post.publishedAt ?? new Date().toISOString();

// AEO/SEO structured data emitted in <head>: custom JSON-LD + FAQPage from faqJson.
const faqEntries = Array.isArray(post.faqJson) ? post.faqJson : [];
const faqLd = faqEntries.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqEntries.map((f: any) => ({
        '@type': 'Question',
        name: f.question ?? f.q ?? '',
        acceptedAnswer: { '@type': 'Answer', text: f.answer ?? f.a ?? '' },
      })),
    }
  : null;
const jsonLd = [post.schemaJson, faqLd].filter(Boolean) as Record<string, unknown>[];
---

<BaseLayout
  title={post.metaTitle ?? post.title}
  description={post.metaDescription ?? post.excerpt ?? ''}
  canonical={`/blog/${post.slug}`}
  type="article"
  publishedTime={pubDate}
  modifiedTime={post.updatedAt}
  image={post.ogImageUrl}
  jsonLd={jsonLd.length ? jsonLd : undefined}
  articleSection={articleSection}
  keywords={postTags}
  author={{ name: SITE.author, url: '/sobre', credentials: 'Autor do DEVDOIDO' }}
>
  <PageShell active="Blog" breadcrumb={[{ label: 'blog', href: '/blog' }, { label: post.slug }]}>
    <!-- Article hero -->
    <section style="padding:48px 0 24px">
      <div class="container-narrow">
        <div class="art-cat"><span class="dot"></span> {post.category ?? 'Blog'}</div>
        <h1 class="art-title">{post.title}</h1>
        <p class="art-sub">{post.excerpt ?? post.subtitle ?? ''}</p>

        <div class="byline">
          <div class="byline-author">
            <div class="avatar avatar-xl">{(SITE.author[0] || 'D').toUpperCase()}</div>
            <div>
              <b>{SITE.author}</b>
              <span>founder &middot; {SITE.name}</span>
            </div>
          </div>
          <div class="byline-meta">
            <span>{pubDate ? new Date(pubDate).toLocaleDateString('pt-BR', { dateStyle: 'long' }).toUpperCase() : ''}</span>
          </div>
        </div>

        <div class="art-cover"><span class="wm">{'{ }'}</span></div>
        <div class="mono-caption" style="text-align:center;margin-bottom:48px">// {post.category ?? 'artigo'}</div>
      </div>
    </section>

    {post.answerBox && (
      <section class="container-narrow">
        <p class="answer-box">{post.answerBox}</p>
      </section>
    )}

    <!-- Article body -->
    <article style="padding-bottom:48px">
      <div class="prose">
        <Fragment set:html={post.contentHtml ?? `<p>${post.excerpt ?? ''}</p>`} />
      </div>
    </article>

    <!-- Tags -->
    <div class="container-narrow">
      <div class="art-tags">
        {post.tags?.map((tag) => (
          <a href={`/blog?tag=${encodeURIComponent(tag.slug)}`} class="tag">#{tag.name}</a>
        ))}
      </div>

      <!-- Author box -->
      <div class="author-box">
        <div class="av">{(SITE.author[0] || 'D').toUpperCase()}</div>
        <div>
          <div class="ab-name">{SITE.author}</div>
          <div class="ab-role">FOUNDER &middot; {SITE.name.toUpperCase()} &middot; @devdoido</div>
          <p>Desenvolvedor full-stack ha 8 anos. Escrevo sobre codigo honesto e negocios indie.</p>
          <div style="display:flex;gap:10px">
            <a href="/sobre" class="btn btn-secondary btn-sm">Ver perfil</a>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div style="display:flex;gap:12px;margin-bottom:64px;flex-wrap:wrap">
        <div style="flex:1;min-width:280px;background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);padding:40px">
          <p class="mono-caption" style="margin-bottom:10px">// comunidade</p>
          <h3 style="font-size:22px;font-weight:700;letter-spacing:-0.02em;margin:0 0 8px">Feed de SaaS brasileiros</h3>
          <p style="font-size:14px;color:var(--fg-muted);margin:0 0 18px;line-height:1.5">Artigos de fintechs, devtools, e-commerces. Direto de quem constroi.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <a href="/feed" class="btn btn-secondary btn-sm">Explorar feed →</a>
          </div>
        </div>
        <div style="flex:1;min-width:280px;background:var(--bg-1);border:1px solid var(--lime-500);border-radius:var(--r-lg);padding:40px;position:relative;overflow:hidden">
          <div style="position:relative">
            <p class="mono-caption" style="margin-bottom:10px">// curso</p>
            <h3 style="font-size:22px;font-weight:700;letter-spacing:-0.02em;margin:0 0 8px">CrazyStack TypeScript</h3>
            <p style="font-size:14px;color:var(--fg-muted);margin:0 0 18px;line-height:1.5">Fullstack do zero ao deploy com Bun, Next, Convex e Claude Code.</p>
            <a href="/cursos/crazystack-typescript" class="btn btn-primary btn-sm">Ver curso →</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Related -->
    {relatedArticles.length > 0 && (
      <section style="border-top:1px solid var(--border);padding:56px 0 80px">
        <div class="page">
          <AsciiRule label="// continue lendo" />
          <h2 class="t-section" style="margin-bottom:32px">Mais nesse beco</h2>
          <div class="article-grid">
            {relatedArticles.map((related, i) => (
              <ArticleCard
                href={`/blog/${related.slug}`}
                category={`// ${related.category ?? 'blog'}`}
                title={related.title}
                date={related.publishedAt ? new Date(related.publishedAt).toLocaleDateString('pt-BR', { dateStyle: 'long' }) : ''}
                display={related.category ?? ''}
                coverColor={coverColors[i % coverColors.length]}
              />
            ))}
          </div>
        </div>
      </section>
    )}
  </PageShell>
</BaseLayout>
