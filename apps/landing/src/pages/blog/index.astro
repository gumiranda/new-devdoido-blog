---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/devdoido/PageShell.astro';
import ArticleCard from '../../components/devdoido/ArticleCard.astro';
import AsciiRule from '../../components/devdoido/AsciiRule.astro';
import { categories, formatDate, posts } from '../../data/devdoido';

const filterGroups = [
  ['Periodo', ['essa semana', 'esse mes', '2026', '2025', '2024', 'todos']],
  ['Formato', ['artigo', 'manifesto', 'tutorial']],
  ['Duracao', ['< 5 min', '5-10 min', 'long read']],
  ['Stack', ['next.js', 'react', 'bun', 'node', 'claude code', 'cursor', 'n8n']],
] as const;
---

<BaseLayout
  title="Blog"
  description="Arquivo do DEVDOIDO: artigos sobre vibe coding, IA, SaaS, carreira e stack moderna sem tutorial de espuma."
  canonical="/blog"
>
  <PageShell active="Home">
    <section style="padding:64px 0 32px;border-bottom:1px solid var(--hairline)">
      <div class="container">
        <p class="t-mono muted" style="margin:0 0 18px;text-transform:uppercase;font-size:12px">◆ /blog · 412 artigos · 8 categorias</p>
        <h1 class="t-display">O Arquivo.</h1>
        <p style="max-width:720px;margin:18px 0 0;color:var(--mute);font-size:19px">
          Tudo que eu ja publiquei. Em ordem cronologica, sem filtro de relevancia. Use o filtro embaixo. Ou role. Voce decide.
        </p>
      </div>
    </section>

    <section style="padding:16px 0;border-bottom:1px solid var(--hairline);position:sticky;top:66px;background:var(--canvas);z-index:50">
      <div class="container" style="display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap">
        <div style="display:flex;gap:6px;flex-wrap:wrap;flex:1" role="group" aria-label="Filtrar por tag">
          <button class="chip blog-filter" aria-pressed="true" data-tag="">Tudo · 412</button>
          {categories.map((category) => (
            <button class="chip blog-filter" data-tag={category.slug}>{category.name} · {category.count}</button>
          ))}
        </div>
        <label style="display:flex;align-items:center;gap:8px">
          <span class="t-caption">ordenar:</span>
          <select class="input" style="min-height:38px;font-family:var(--font-ui)">
            <option>+ recentes</option>
            <option>+ lidos</option>
            <option>+ comentados</option>
          </select>
        </label>
      </div>
    </section>

    <section class="section">
      <div class="container" style="display:grid;grid-template-columns:220px minmax(0,1fr);gap:48px" id="blog-layout">
        <div>
          {filterGroups.map(([title, rows]) => (
            <div style="margin-bottom:32px">
              <p class="t-body-strong" style="margin:0 0 12px">{title}</p>
              <div style="display:flex;flex-direction:column">
                {rows.map((row, index) => (
                  <button style="min-height:44px;display:flex;justify-content:space-between;align-items:center;padding:10px 0;background:none;border:0;color:var(--ink);cursor:pointer;text-align:left">
                    <span>{row}</span>
                    <span class="muted">({index * 7 + 12})</span>
                  </button>
                ))}
              </div>
            </div>
          ))}
        </div>
        <div>
          <AsciiRule label="// cronologia · maio 2026" />
          <div class="article-grid" style="--grid-cols:3" id="blog-posts-list">
            {posts.map((post) => (
              <div class="blog-post-item" data-tags={[post.categorySlug, ...post.tags].join(' ')}>
                <ArticleCard
                  href={`/blog/${post.slug}`}
                  category={`// ${post.category} · ${post.minutes} min`}
                  title={post.title}
                  date={formatDate(post.pubDate)}
                  reads={post.reads}
                  kind={post.kind}
                  display={post.display}
                  badges={post.badges}
                />
              </div>
            ))}
          </div>
          <div style="margin-top:64px;padding:32px 0;border-top:1px solid var(--hairline);display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap">
            <span class="t-caption">mostrando 1-12 de 412</span>
            <div style="display:flex;gap:4px;align-items:center">
              <button class="btn-icon" disabled aria-label="Anterior">←</button>
              <button class="chip" aria-pressed="true">1</button>
              <button class="chip">2</button>
              <button class="chip">3</button>
              <span class="t-caption" style="padding:0 8px">...</span>
              <button class="chip">35</button>
              <button class="btn-icon" aria-label="Proxima">→</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </PageShell>

  <script>
    (function() {
      var buttons = document.querySelectorAll('.blog-filter');
      var items = document.querySelectorAll('.blog-post-item');
      function setTag(tag) {
        buttons.forEach(function(btn) {
          btn.setAttribute('aria-pressed', btn.getAttribute('data-tag') === tag ? 'true' : 'false');
        });
        items.forEach(function(item) {
          var tags = (item.getAttribute('data-tags') || '').split(' ').filter(Boolean);
          (item as HTMLElement).style.display = !tag || tags.indexOf(tag) !== -1 ? '' : 'none';
        });
      }
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTag(btn.getAttribute('data-tag') || '');
        });
      });
      var initialTag = new URLSearchParams(window.location.search).get('tag') || '';
      if (initialTag) setTag(initialTag);
    })();
  </script>
</BaseLayout>
