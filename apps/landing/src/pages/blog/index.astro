---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/devdoido/PageShell.astro';
import ArticleCard from '../../components/devdoido/ArticleCard.astro';
import AsciiRule from '../../components/devdoido/AsciiRule.astro';
import { categories, formatDate, posts } from '../../data/devdoido';

const coverColors = ['a', 'b', 'c', 'd', 'e', 'f', 'a', 'b', 'c', 'd', 'e', 'f'];
---

<BaseLayout
  title="Blog"
  description="Arquivo do DEVDOIDO: artigos sobre vibe coding, IA, SaaS, carreira e stack moderna sem tutorial de espuma."
  canonical="/blog"
>
  <PageShell active="Blog" breadcrumb={[{ label: 'blog' }]}>
    <!-- Masthead -->
    <header class="masthead">
      <div class="page">
        <div class="crumb">
          <a href="/">home</a><span class="sep">/</span><span class="here">blog</span>
        </div>
        <h1 class="t-display">Codigo <span style="color:var(--lime-400)">escrito</span>.<br />Nao <span style="color:var(--lime-400)">colado</span>.</h1>
        <p class="lede" style="max-width:620px">
          <strong>412 artigos</strong> sobre Node.js, React, Next.js, IA, SaaS e carreira dev. Tutoriais tecnicos de verdade — sem clickbait, sem prompt magico, sem "revolucione sua carreira".
        </p>
        <div class="blog-meta">
          <div>ARTIGOS <b class="accent">412</b></div>
          <div>CATEGORIAS <b>8</b></div>
          <div>AUTOR <b>@devdoido</b></div>
          <div>FREQUENCIA <b>3 posts/semana</b></div>
          <div>ULTIMO UPDATE <b>2026.05.29</b></div>
        </div>
      </div>
    </header>

    <!-- Filter bar -->
    <div class="filter-bar" style="top:66px">
      <div class="inner">
        <label class="search-pill" style="max-width:560px">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/></svg>
          <input placeholder="buscar artigo, tag ou categoria..." />
          <span class="kbd">⌘K</span>
        </label>
        <div style="display:flex;align-items:center;gap:10px">
          <span class="mono-caption">ordenar</span>
          <div class="sort-pills">
            <span class="sort-pill active">recentes</span>
            <span class="sort-pill">populares</span>
            <span class="sort-pill">curtos</span>
          </div>
        </div>
      </div>
      <div class="cat-chips">
        <button class="chip blog-filter" aria-pressed="true" data-tag="">Todos</button>
        {categories.map((category) => (
          <button class="chip blog-filter" data-tag={category.slug}>{category.name}<span class="count">{category.count}</span></button>
        ))}
      </div>
    </div>

    <!-- Posts grid -->
    <section style="padding:72px 0;border-bottom:1px solid var(--border)">
      <div class="page" style="display:grid;grid-template-columns:1fr 320px;gap:64px;align-items:start" class="grid-layout">
        <div>
          <AsciiRule label="// cronologia &middot; maio 2026" />
          <div class="article-grid" style="--grid-cols:2">
            {posts.map((post, i) => (
              <div class="blog-post-item" data-tags={[post.categorySlug, ...post.tags].join(' ')}>
                <ArticleCard
                  href={`/blog/${post.slug}`}
                  category={`// ${post.category} &middot; ${post.minutes} min`}
                  title={post.title}
                  date={formatDate(post.pubDate)}
                  reads={post.reads}
                  display={post.display}
                  badges={post.badges}
                  coverColor={coverColors[i % coverColors.length]}
                />
              </div>
            ))}
          </div>

          <!-- Pagination -->
          <div class="pager">
            <span class="pg">←</span>
            <span class="pg active">1</span>
            <span class="pg">2</span>
            <span class="pg">3</span>
            <span class="pg">4</span>
            <span class="dots">...</span>
            <span class="pg">35</span>
            <span class="pg">→</span>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
          <div class="side-card newsletter-card">
            <div class="tag-line">// curso · 14h de conteudo</div>
            <h3>&gt;_ CrazyStack TS</h3>
            <p>Fullstack do zero ao deploy com Bun, Next, Convex e Claude Code. R$ 497.</p>
            <div style="display:flex;gap:8px">
              <a href="/cursos/crazystack-typescript" class="btn btn-primary btn-sm" style="flex:1;justify-content:center">ver curso</a>
            </div>
            <div class="sub">// 8.2k alunos · acesso vitalicio · garantia 30d</div>
          </div>

          <div class="side-card">
            <h3>Top da semana <span class="num">/05</span></h3>
            <div class="pop-list">
              {posts.slice(0, 5).map((post, i) => (
                <div class="pop-item">
                  <span class="num">0{i + 1}</span>
                  <div>
                    <a href={`/blog/${post.slug}`} class="t">{post.title}</a>
                    <span class="pop-meta">{post.category.toUpperCase()} &middot; {post.reads} views</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="side-card">
            <h3>Stats do blog <span class="num">/live</span></h3>
            <div class="mini-stats">
              <div class="mini-stat"><b>412</b><span>artigos</span></div>
              <div class="mini-stat"><b>284k</b><span>views/mes</span></div>
              <div class="mini-stat"><b>3.2k</b><span>assinantes</span></div>
              <div class="mini-stat"><b>7y</b><span>escrevendo</span></div>
            </div>
          </div>

          <div class="side-card">
            <h3>Tags <span class="num">/24</span></h3>
            <div class="tag-cloud">
              {['nodejs','react','nextjs','typescript','claude-code','cursor','fastify','prisma','drizzle','trpc','tailwind','shadcn-ui','clean-arch','docker','postgres','mongodb','saas','indie-hacking','carreira','ia'].map((t) => (
                <span class="tg">{t}</span>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </section>
  </PageShell>

  <script>
    (function() {
      var buttons = document.querySelectorAll('.blog-filter');
      var items = document.querySelectorAll('.blog-post-item');
      function setTag(tag) {
        buttons.forEach(function(btn) {
          btn.setAttribute('aria-pressed', btn.getAttribute('data-tag') === tag ? 'true' : 'false');
        });
        items.forEach(function(item) {
          var tags = (item.getAttribute('data-tags') || '').split(' ').filter(Boolean);
          (item as HTMLElement).style.display = !tag || tags.indexOf(tag) !== -1 ? '' : 'none';
        });
      }
      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          setTag(btn.getAttribute('data-tag') || '');
        });
      });
      var initialTag = new URLSearchParams(window.location.search).get('tag') || '';
      if (initialTag) setTag(initialTag);
    })();
  </script>
</BaseLayout>
