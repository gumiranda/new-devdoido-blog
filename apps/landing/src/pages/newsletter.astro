---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/devdoido/PageShell.astro';
import TypeStage from '../components/devdoido/TypeStage.astro';
import AsciiRule from '../components/devdoido/AsciiRule.astro';
import { newsletterEditions } from '../data/devdoido';
---

<BaseLayout
  title="Newsletter"
  description="DEVDOIDO Weekly: 1 email por semana, 3 links, 1 opiniao impopular e 1 trecho de codigo em producao."
  canonical="/newsletter"
>
  <PageShell active="Home" breadcrumb={[{ label: 'newsletter' }]}>
    <section style="background:var(--fg);color:#0a0a0a;position:relative;overflow:hidden;min-height:720px">
      <TypeStage word="WEEKLY" invert density={0.08} />
      <div style="position:relative;padding:80px 0 120px;z-index:1">
        <div class="page">
          <span class="mono-caption" style="color:#0a0a0a;opacity:.6">// devdoido weekly &middot; #142 &middot; quinta 06:00 BRT</span>
          <h1 class="t-display" style="color:#0a0a0a;margin-top:24px">1 EMAIL.<br />0 BS.</h1>
          <p style="max-width:660px;margin:32px 0 0;color:#0a0a0a;opacity:.85;font-size:22px;line-height:1.5">
            Toda quinta-feira as 6h da manha. 3 links que eu li essa semana, 1 opiniao impopular, 1 trecho de codigo que ta rodando em producao. 5 minutos de leitura.
          </p>
          <form style="display:flex;gap:8px;margin-top:48px;max-width:580px;flex-wrap:wrap">
            <input class="input" style="flex:1;min-width:220px;border-color:rgba(0,0,0,.3);color:#0a0a0a;background:transparent" placeholder="seu@email.com" />
            <button class="btn btn-primary" style="background:#0a0a0a;color:var(--fg);min-height:56px;padding:0 32px">Assinar &rarr;</button>
          </form>
          <div class="t-mono" style="display:flex;gap:24px;margin-top:48px;color:#0a0a0a;opacity:.55;font-size:12px;flex-wrap:wrap">
            <span>12,847 inscritos</span>
            <span>open rate 64%</span>
            <span>0 spam</span>
            <span>unsubscribe 1-click</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="border-bottom:none">
      <div class="page">
        <AsciiRule label="// what's inside" />
        <h2 class="t-section" style="margin-bottom:48px">O que vem dentro</h2>
        <div class="article-grid">
          {[
            ['01', '3 LINKS', '3 artigos, videos ou tools que eu realmente li essa semana. Com comentario curto, nao resumo automatico.'],
            ['02', '1 OPINIAO', 'A opiniao impopular da semana. Sobre IA, framework, dev culture e mercado. Geralmente errada. Sempre honesta.'],
            ['03', '1 CODIGO', 'Um trecho de codigo que ta rodando em producao essa semana. Com o motivo de ter ficado assim.'],
          ].map(([n, title, body]) => (
            <div class="tile" style="min-height:360px;align-items:stretch;flex-direction:column;justify-content:space-between">
              <span class="mono-caption">// item.{n}</span>
              <div>
                <h3 style="font-size:56px;font-weight:800;line-height:.94;margin-bottom:18px;letter-spacing:-0.02em">{title}</h3>
                <p style="margin:0;color:var(--fg-muted);line-height:1.5">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="page">
        <AsciiRule label="// ultimas edicoes" />
        <div style="margin-top:32px">
          {newsletterEditions.map(([number, date, title, reads]) => (
            <a href="/newsletter" style="display:grid;grid-template-columns:80px 140px minmax(0,1fr) 160px 24px;gap:24px;padding:24px 0;border-top:1px solid var(--border);align-items:center;text-decoration:none;color:var(--fg)" class="edition-row">
              <span style="font-size:32px;font-weight:800;letter-spacing:-0.02em">{number}</span>
              <span class="t-mono muted" style="font-size:12px">{date}</span>
              <span style="font-size:19px;font-weight:700">{title}</span>
              <span class="t-mono muted" style="font-size:12px;text-align:right">{reads}</span>
              <span>&rarr;</span>
            </a>
          ))}
          <div style="height:1px;background:var(--border)"></div>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
