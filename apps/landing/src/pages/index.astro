---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/devdoido/PageShell.astro';
import TypeStage from '../components/devdoido/TypeStage.astro';
import ArticleCard from '../components/devdoido/ArticleCard.astro';
import AsciiRule from '../components/devdoido/AsciiRule.astro';
import Terminal from '../components/devdoido/Terminal.astro';
import { categories, featuredPost, posts, SITE } from '../data/devdoido';

const trending = posts.slice(1, 4);
const latest = posts.slice(4, 12);
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  canonical="/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: SITE.title,
    description: SITE.description,
    url: SITE.url,
    inLanguage: 'pt-BR',
  }}
>
  <PageShell active="Home">
    <section class="section" style="padding-top:32px">
      <div class="container">
        <div class="tile tile-hero" style="padding:0;justify-content:flex-end">
          <TypeStage word="DEVDOIDO" density={0.07} />
          <div style="position:absolute;top:32px;left:32px;display:flex;gap:8px;z-index:1;flex-wrap:wrap">
            <span class="badge">edicao #142</span>
            <span class="badge badge-solid">manifesto</span>
          </div>
          <div class="t-mono muted hero-meta" style="position:absolute;top:32px;right:32px;text-align:right;z-index:1;font-size:11px;line-height:1.6">
            published 15.MAY.2026<br />
            reading time 04:12<br />
            reads 12,847
          </div>
          <div style="position:relative;z-index:1;padding:48px">
            <p class="t-mono muted" style="margin:0 0 18px;text-transform:uppercase;font-size:12px">◆ artigo da semana · vibe coding</p>
            <h1 class="t-display">
              Pare de aprender<br />framework. Aprenda<br />a <span style="color:var(--sale)">pensar.</span>
            </h1>
            <p class="tile-sub">
              Voce nao precisa de mais um curso de Next.js. Voce precisa parar de tratar IDE como tutorial e codigo como cargo. O artigo que ninguem quis publicar.
            </p>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <a class="btn" href={`/blog/${featuredPost.slug}`}>Ler agora →</a>
              <a class="btn btn-secondary" href="/blog">+412 artigos no arquivo</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container">
      <AsciiRule label="// trending now · 7d" />
    </div>

    <section class="section" style="padding-top:8px">
      <div class="container">
        <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;margin-bottom:32px">
          <h2 class="t-section">Em alta na bolha</h2>
          <a href="/blog" class="t-mono" style="color:var(--ink)">ver tudo →</a>
        </div>
        <div class="article-grid">
          {trending.map((post) => (
            <ArticleCard
              href={`/blog/${post.slug}`}
              category={`// ${post.category} · ${post.minutes} min`}
              title={post.title}
              date="MAY"
              reads={post.reads}
              kind={post.kind}
              display={post.display}
              badges={post.badges}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <AsciiRule label="// browse by categoria" />
        <div class="category-grid">
          {categories.slice(0, 4).map((category) => (
            <a class="cat-tile" href={category.slug === 'vibe-coding' ? '/categoria/vibe-coding' : `/blog?tag=${category.slug}`}>
              <div class="stage-grid"></div>
              <div style="position:relative;z-index:1;width:100%;display:flex;align-items:flex-end;justify-content:space-between;gap:16px">
                <h3 class="cat-tile-name">{category.name}</h3>
                <span class="t-mono muted" style="font-size:11px">{category.count} posts</span>
              </div>
            </a>
          ))}
        </div>
        <div class="category-grid" style="margin-top:8px">
          {categories.slice(4).map((category) => (
            <a class="cat-tile" style="min-height:150px" href={`/blog?tag=${category.slug}`}>
              <div class="stage-mono"></div>
              <div style="position:relative;z-index:1;width:100%;display:flex;align-items:flex-end;justify-content:space-between;gap:16px">
                <h3 class="cat-tile-name" style="font-size:32px">{category.name}</h3>
                <span class="t-mono muted" style="font-size:11px">{category.count} posts</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="two-col home-feature-grid" style="gap:8px">
          <div class="tile" style="min-height:520px;padding:0;color:var(--canvas);justify-content:flex-end">
            <TypeStage word="CRAZY" invert density={0.16} />
            <div style="position:relative;z-index:1;padding:48px">
              <span class="badge" style="background:transparent;color:var(--canvas);border-color:rgba(255,255,255,0.3)">bootcamp · 14h · 2026</span>
              <h2 class="t-display" style="margin-top:24px;color:var(--canvas)">CrazyStack<br />TypeScript</h2>
              <p style="max-width:520px;margin:24px 0 32px;color:var(--canvas);opacity:.82;font-size:17px">
                Fullstack do zero ao deploy com Claude Code, Bun, Next 16, Convex e n8n. Nao e teoria, e stack em producao.
              </p>
              <div style="display:flex;gap:12px;flex-wrap:wrap">
                <a class="btn btn-outline-on-image" href="/cursos/crazystack-typescript">Ver modulos →</a>
                <span class="btn btn-ghost" style="color:var(--canvas);border-color:rgba(255,255,255,0.3)">R$ 497 · 60% OFF</span>
              </div>
            </div>
          </div>
          <div class="tile" style="min-height:520px">
            <div style="position:relative;z-index:1;width:100%">
              <p class="t-mono muted" style="font-size:11px;margin:0 0 18px;text-transform:uppercase">◆ manifesto v.0.4</p>
              <Terminal title="cat MANIFESTO.md" accent>
                <span class="term-accent"># devdoido nao e tutorial.</span><br />
                <span class="term-accent"># e o que sobra depois que</span><br />
                <span># o hype acaba.</span><br /><br />
                <span class="term-prompt">&gt;</span> conteudo sem rodeio<br />
                <span class="term-prompt">&gt;</span> opiniao sem patrocinador<br />
                <span class="term-prompt">&gt;</span> codigo que roda em prod<br />
                <span class="term-prompt">&gt;</span> zero promessa de salario<br /><br />
                <span class="term-prompt">$</span> <span class="term-accent">ler manifesto completo</span><span class="cursor"></span>
              </Terminal>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top:0">
      <div class="container">
        <AsciiRule label="// ultimos publicados" />
        <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;margin-bottom:32px;flex-wrap:wrap">
          <h2 class="t-section">Saiu fresquinho</h2>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="chip" aria-pressed="true">Tudo</button>
            <button class="chip">Vibe</button>
            <button class="chip">IA</button>
            <button class="chip">SaaS</button>
            <button class="chip">Carreira</button>
          </div>
        </div>
        <div class="article-grid" style="--grid-cols:4">
          {latest.map((post) => (
            <ArticleCard
              href={`/blog/${post.slug}`}
              category={`// ${post.category} · ${post.minutes} min`}
              title={post.title}
              date="MAY"
              reads={post.reads}
              kind={post.kind}
              display={post.display}
              badges={post.badges}
            />
          ))}
        </div>
        <div class="center" style="margin-top:48px">
          <a class="btn btn-secondary" href="/blog">Ver +404 artigos →</a>
        </div>
      </div>
    </section>

    <section style="background:var(--ink);color:var(--canvas);padding:80px 0">
      <div class="container two-col" style="align-items:center;gap:64px">
        <div>
          <p class="t-mono" style="margin:0 0 18px;color:var(--canvas);opacity:.6;text-transform:uppercase;font-size:12px">◆ newsletter · toda quinta · 6h da manha</p>
          <h2 class="t-display" style="color:var(--canvas)">1 email.<br />0 conselho<br />de coach.</h2>
        </div>
        <div>
          <p style="max-width:480px;margin:0 0 24px;color:var(--canvas);opacity:.8;font-size:17px">
            Toda quinta: 3 links, 1 opiniao impopular, 1 trecho de codigo que esta em producao.
          </p>
          <form style="display:flex;gap:8px;max-width:500px;flex-wrap:wrap" action="/newsletter">
            <input class="input" style="flex:1;min-width:220px;border-color:rgba(255,255,255,0.3);color:var(--canvas)" placeholder="seu@email.com" />
            <button class="btn btn-accent">Assinar →</button>
          </form>
          <p class="t-mono" style="margin:12px 0 0;color:var(--canvas);opacity:.5;font-size:11px">12,847 devs · 0% spam · 1 unsubscribe-click</p>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
