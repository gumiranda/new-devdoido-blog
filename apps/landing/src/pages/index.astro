---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/devdoido/PageShell.astro';
import TypeStage from '../components/devdoido/TypeStage.astro';
import ArticleCard from '../components/devdoido/ArticleCard.astro';
import AsciiRule from '../components/devdoido/AsciiRule.astro';
import Terminal from '../components/devdoido/Terminal.astro';
import { categories, featuredPost, posts, SITE } from '../data/devdoido';

const trending = posts.slice(1, 4);
const latest = posts.slice(4, 12);
const coverColors = ['a', 'b', 'c', 'd', 'e', 'f', 'a', 'b'];
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  canonical="/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: SITE.title,
    description: SITE.description,
    url: SITE.url,
    inLanguage: 'pt-BR',
  }}
>
  <PageShell active="Home" breadcrumb={[]}>
    <!-- HERO -->
    <section class="hero">
      <div class="page hero-grid">
        <div>
          <span class="kicker"><span class="dot"></span> Codigo na unha. Sem muleta.</span>
          <h1 class="t-display" style="margin:24px 0 20px">
            Pare de aprender<br />framework. Aprenda<br />a <span style="color:var(--lime-400)">pensar.</span>
          </h1>
          <p class="lede">
            Voce nao precisa de mais um curso de Next.js. Voce precisa parar de tratar IDE como tutorial e codigo como cargo. <strong>O artigo que ninguem quis publicar.</strong>
          </p>
          <div class="hero-meta">
            <div>ARTIGOS <b>412</b></div>
            <div>NEWSLETTER <b>12.8k</b></div>
            <div>YOUTUBE <b>48k</b></div>
            <div>RATING <b>4.9 ★</b></div>
          </div>
          <div class="hero-cta">
            <a class="btn btn-primary btn-lg" href={`/blog/${featuredPost.slug}`}>
              Ler agora
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <a class="btn btn-outline" href="/blog">+412 artigos</a>
            <a class="btn btn-ghost" href="/feed">Feed da comunidade →</a>
          </div>
        </div>

        <!-- Hero terminal -->
        <div>
          <Terminal title="gustavo@devdoido · module-01">
            <span class="prompt">gustavo@stack</span> <span class="comment">~ $</span> <span class="fn">git</span> <span class="kw">clone</span> <span class="str">"devdoido.com.br"</span><br />
            <span class="comment">// clonando na unha. sem muleta.</span><br />
            <span class="prompt">gustavo@stack</span> <span class="comment">~ $</span> <span class="fn">bun</span> <span class="kw">install</span><br />
            <span class="comment">// &check; 184 packages &middot; 3.2s</span><br />
            <span class="prompt">gustavo@stack</span> <span class="comment">~ $</span> <span class="fn">bun</span> run dev<br />
            <span style="color:var(--lime-400)">&#x25B8; server ready at :3333</span><br />
            <span class="prompt">gustavo@stack</span> <span class="comment">~ $</span> <span class="cursor"></span>
          </Terminal>
          <div class="term-tiles">
            <div class="term-tile"><b>412</b><span>artigos</span></div>
            <div class="term-tile"><b>12.8k</b><span>newsletter</span></div>
            <div class="term-tile"><b>4.9</b><span>rating</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stack strip -->
    <div class="stack-strip">
      <div class="inner">
        <span class="lbl">// stack coberta</span>
        <div class="items">
          <span>Node.js</span><span>React</span><span>Next.js 16</span><span>React Native</span>
          <span>TypeScript</span><span>Bun</span><span>Convex</span><span>Claude Code</span>
          <span>n8n</span><span>Tailwind</span>
        </div>
      </div>
    </div>

    <!-- Trending -->
    <section class="section" style="border-bottom:none;padding-bottom:48px">
      <div class="page">
        <AsciiRule label="// trending now &middot; 7d" />
        <div class="article-grid">
          {trending.map((post, i) => (
            <ArticleCard
              href={`/blog/${post.slug}`}
              category={`// ${post.category} &middot; ${post.minutes} min`}
              title={post.title}
              date="MAY"
              reads={post.reads}
              display={post.display}
              badges={post.badges}
              coverColor={coverColors[i % coverColors.length]}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- Categories -->
    <section class="section-sm">
      <div class="page">
        <AsciiRule label="// browse by categoria" />
        <div class="category-grid">
          {categories.slice(0, 4).map((category) => (
            <a class="cat-tile" href={category.slug === 'vibe-coding' ? '/categoria/vibe-coding' : `/blog?tag=${category.slug}`}>
              <div class="stage-grid-bg"></div>
              <div style="position:relative;z-index:1;width:100%;display:flex;align-items:flex-end;justify-content:space-between;gap:16px">
                <h3 class="cat-tile-title">{category.name}</h3>
                <span class="t-mono muted" style="font-size:11px">{category.count} posts</span>
              </div>
            </a>
          ))}
        </div>
        <div class="category-grid" style="margin-top:8px">
          {categories.slice(4).map((category) => (
            <a class="cat-tile" style="min-height:150px" href={`/blog?tag=${category.slug}`}>
              <div class="stage-grid-bg"></div>
              <div style="position:relative;z-index:1;width:100%;display:flex;align-items:flex-end;justify-content:space-between;gap:16px">
                <h3 class="cat-tile-title" style="font-size:32px">{category.name}</h3>
                <span class="t-mono muted" style="font-size:11px">{category.count} posts</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CrazyStack promo -->
    <section class="section-sm">
      <div class="page">
        <div class="two-col home-feature-grid" style="gap:8px">
          <div class="tile" style="min-height:520px;padding:0;justify-content:flex-end;background:var(--fg);border-color:var(--fg);color:#0a0a0a">
            <TypeStage word="CRAZY" invert density={0.16} />
            <div style="position:relative;z-index:1;padding:48px">
              <span class="badge" style="background:transparent;color:#0a0a0a;border-color:rgba(0,0,0,.3)">bootcamp &middot; 14h &middot; 2026</span>
              <h2 class="t-display" style="margin-top:24px;color:#0a0a0a">CrazyStack<br />TypeScript</h2>
              <p style="max-width:520px;margin:24px 0 32px;color:#0a0a0a;opacity:.82;font-size:17px">
                Fullstack do zero ao deploy com Claude Code, Bun, Next 16, Convex e n8n. Nao e teoria, e stack em producao.
              </p>
              <div style="display:flex;gap:12px;flex-wrap:wrap">
                <a class="btn btn-primary" href="/cursos/crazystack-typescript" style="background:#0a0a0a;color:var(--fg)">Ver modulos &rarr;</a>
                <span class="badge badge-dark" style="background:transparent;color:#0a0a0a;border-color:rgba(0,0,0,.3)">R$ 497 &middot; 60% OFF</span>
              </div>
            </div>
          </div>
          <div class="tile" style="min-height:520px">
            <div style="position:relative;z-index:1;width:100%">
              <p class="mono-caption" style="margin:0 0 18px">// manifesto v.0.4</p>
              <Terminal title="cat MANIFESTO.md">
                <span class="prompt"># devdoido nao e tutorial.</span><br />
                <span class="prompt"># e o que sobra depois que</span><br />
                <span># o hype acaba.</span><br /><br />
                <span class="comment">&gt;</span> conteudo sem rodeio<br />
                <span class="comment">&gt;</span> opiniao sem patrocinador<br />
                <span class="comment">&gt;</span> codigo que roda em prod<br />
                <span class="comment">&gt;</span> zero promessa de salario<br /><br />
                <span class="comment">$</span> <span class="prompt">ler manifesto completo</span><span class="cursor"></span>
              </Terminal>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest posts -->
    <section class="section" style="border-bottom:none">
      <div class="page">
        <AsciiRule label="// ultimos publicados" />
        <div style="display:flex;align-items:baseline;justify-content:space-between;gap:24px;margin-bottom:32px;flex-wrap:wrap">
          <h2 class="t-section">Saiu fresquinho</h2>
          <div style="display:flex;gap:6px;flex-wrap:wrap">
            <button class="chip" aria-pressed="true">Tudo</button>
            <button class="chip">Vibe</button>
            <button class="chip">IA</button>
            <button class="chip">SaaS</button>
            <button class="chip">Carreira</button>
          </div>
        </div>
        <div class="article-grid" style="--grid-cols:4">
          {latest.map((post, i) => (
            <ArticleCard
              href={`/blog/${post.slug}`}
              category={`// ${post.category} &middot; ${post.minutes} min`}
              title={post.title}
              date="MAY"
              reads={post.reads}
              display={post.display}
              badges={post.badges}
              coverColor={coverColors[i % coverColors.length]}
            />
          ))}
        </div>
        <div style="display:flex;justify-content:center;margin-top:48px">
          <a class="btn btn-secondary" href="/blog">Ver +404 artigos &rarr;</a>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section style="background:var(--fg);color:#0a0a0a;padding:80px 0">
      <div class="page two-col" style="align-items:center;gap:64px">
        <div>
          <p class="mono-caption" style="color:#0a0a0a;opacity:.6">// newsletter &middot; toda quinta &middot; 6h da manha</p>
          <h2 class="t-display" style="color:#0a0a0a">1 email.<br />0 conselho<br />de coach.</h2>
        </div>
        <div>
          <p style="max-width:480px;margin:0 0 24px;color:#0a0a0a;opacity:.8;font-size:17px">
            Toda quinta: 3 links, 1 opiniao impopular, 1 trecho de codigo que esta em producao.
          </p>
          <form style="display:flex;gap:8px;max-width:500px;flex-wrap:wrap" action="/newsletter">
            <input class="input" style="flex:1;min-width:220px;border-color:rgba(0,0,0,.3);color:#0a0a0a;background:transparent" placeholder="seu@email.com" />
            <button class="btn btn-primary" style="background:#0a0a0a;color:var(--fg)">Assinar &rarr;</button>
          </form>
          <p class="mono-caption" style="margin:12px 0 0;color:#0a0a0a;opacity:.6">12,847 devs &middot; 0% spam &middot; 1 unsubscribe-click</p>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
