---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageShell from '../../components/devdoido/PageShell.astro';
import TypeStage from '../../components/devdoido/TypeStage.astro';
import AsciiRule from '../../components/devdoido/AsciiRule.astro';
import { courseModules } from '../../data/devdoido';
---

<BaseLayout
  title="CrazyStack TypeScript"
  description="Bootcamp CrazyStack TypeScript: fullstack do zero ao deploy com Bun, Next, Convex, Claude Code e n8n."
  canonical="/cursos/crazystack-typescript"
>
  <PageShell active="Cursos">
    <section style="padding:48px 0 0">
      <div class="page">
        <div class="tile tile-hero" style="min-height:760px;padding:0;background:var(--fg);border-color:var(--fg);color:#0a0a0a">
          <TypeStage word="CRAZYSTACK" invert density={0.1} />
          <img src="/devdoido/crazystack.png" alt="" style="position:absolute;right:32px;top:96px;width:min(36%,420px);z-index:1;border:1px solid rgba(0,0,0,.2);border-radius:var(--r-lg)" />
          <div style="position:absolute;top:32px;left:32px;display:flex;gap:8px;z-index:2;flex-wrap:wrap">
            <span class="badge" style="background:transparent;color:#0a0a0a;border-color:rgba(0,0,0,.3)">bootcamp &middot; 14h</span>
            <span class="badge badge-danger">-60% ate domingo</span>
            <span class="badge" style="background:transparent;color:#0a0a0a;border-color:rgba(0,0,0,.3)">turma #03</span>
          </div>
          <div class="t-mono" style="position:absolute;top:32px;right:32px;text-align:right;z-index:2;font-size:11px;color:#0a0a0a;opacity:.65;line-height:1.6">
            proxima turma &middot; 22.MAY.2026<br />
            vagas restantes &middot; 47 / 200<br />
            v.2026.05 &middot; last update 14.MAY
          </div>
          <div style="position:relative;z-index:2;padding:48px;max-width:980px">
            <h1 class="t-display" style="color:#0a0a0a">CrazyStack<br />TypeScript.</h1>
            <p class="tile-sub" style="color:#0a0a0a;opacity:.86">
              Fullstack do zero ao deploy com Bun, Next 16, Convex, Claude Code e n8n. Nao e tutorial de hello-world. E a stack que eu uso em producao.
            </p>
            <div style="display:flex;gap:12px;align-items:center;margin-top:32px;flex-wrap:wrap">
              <a class="btn btn-primary btn-lg" href="#pricing" style="background:#0a0a0a;color:var(--fg)">Garantir vaga &middot; R$ 497 &rarr;</a>
              <a class="btn btn-ghost" style="color:#0a0a0a;border-color:rgba(0,0,0,.3)" href="#modules">Aula 0 gratis</a>
              <span class="t-mono" style="color:#0a0a0a;opacity:.65;font-size:12px">parcela em 12x &middot; R$ 49,70</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="border-bottom:none">
      <div class="page">
        <AsciiRule label="// o que voce vai construir" />
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:24px;margin-bottom:32px;flex-wrap:wrap">
          <h2 class="t-section">3 apps reais.<br />Em producao.</h2>
          <span class="t-mono muted" style="font-size:12px">modulos 4-10</span>
        </div>
        <div class="mod-grid">
          {[
            ['01', 'WhatsApp Bot SaaS', ['bun', 'convex', 'wpp api'], 'Bot multi-tenant com fila, billing e dashboard.'],
            ['02', 'AI Content Engine', ['next 16', 'claude api', 'n8n'], 'Pipeline que pega topico, pesquisa, escreve e publica.'],
            ['03', 'Dev Tools Marketplace', ['next 16', 'stripe', 'convex'], 'Marketplace para dev tools com auth, pagamento e painel.'],
          ].map(([n, name, stack, body]) => (
            <div class="mod">
              <div class="mod-num">build.{n}</div>
              <div class="mod-ic">
                <svg class="i" fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </div>
              <h3>{name}</h3>
              <p>{body}</p>
              <div class="tags">
                {(stack as string[]).map((item) => <span class="tag">{item}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="modules">
      <div class="page">
        <AsciiRule label="// curriculum.json" />
        <div style="display:flex;justify-content:space-between;align-items:baseline;gap:24px;margin-bottom:32px;flex-wrap:wrap">
          <h2 class="t-section">10 modulos &middot; 14h.</h2>
          <span class="t-mono muted" style="font-size:12px">todos com codigo aberto no github</span>
        </div>
        {courseModules.map(([number, name, time, body], index) => (
          <details class="faq" style="border-radius:0;border-left:none;border-right:none;border-top:1px solid var(--border);border-bottom:0">
            <summary class="curriculum-row" style="list-style:none;padding:20px 0;display:grid;grid-template-columns:80px minmax(0,1fr) 100px 80px 24px;gap:24px;align-items:center;cursor:pointer">
              <span style="font-size:28px;font-weight:800;letter-spacing:-0.02em">{number}</span>
              <span style="font-size:19px;font-weight:700">{name}</span>
              <span class="t-mono muted" style="font-size:12px">{time}</span>
              <span class="t-mono muted" style="font-size:11px">{index === 0 ? 'gratis' : 'incluso'}</span>
              <span class="marker">+</span>
            </summary>
            <p style="padding:0 0 24px 104px;color:var(--fg-muted);font-size:16px;max-width:720px">{body}</p>
          </details>
        ))}
        <div style="height:1px;background:var(--border)"></div>
      </div>
    </section>

    <section class="section" id="pricing">
      <div class="page">
        <AsciiRule label="// pricing.txt" />
        <div class="two-col" style="gap:8px">
          <div class="tile" style="min-height:auto">
            <span class="mono-caption">// plano.solo</span>
            <h3 style="font-size:64px;font-weight:800;letter-spacing:-0.025em;line-height:1;margin:12px 0">R$ 497</h3>
            <p class="t-mono muted" style="font-size:12px">12x R$ 49,70 &middot; acesso vitalicio</p>
            <ul style="padding-left:0;list-style:none;margin:24px 0;font-size:15px">
              {['14h de aula + 3 projetos completos', 'Codigo no github', 'Atualizacoes vitalicias', 'Discord da turma &middot; 1 ano', 'Nao inclui mentoria'].map((item) => (
                <li style="padding:6px 0;display:flex;gap:12px"><span class="muted">-</span><span>{item}</span></li>
              ))}
            </ul>
            <a class="btn btn-primary" href="#pricing">Garantir vaga &rarr;</a>
          </div>
          <div style="background:var(--fg);color:#0a0a0a;padding:48px;border-radius:var(--r-lg);border:1px solid var(--lime-500);box-shadow:var(--glow);position:relative">
            <span class="badge badge-solid" style="position:absolute;top:24px;right:24px">recomendado</span>
            <span class="mono-caption" style="color:#0a0a0a;opacity:.6">// plano.pro</span>
            <h3 style="font-size:64px;font-weight:800;letter-spacing:-0.025em;line-height:1;margin:12px 0;color:#0a0a0a">R$ 1.297</h3>
            <p style="color:#0a0a0a;opacity:.7;font-size:14px">12x R$ 129,70 &middot; vitalicio + mentoria</p>
            <ul style="padding-left:0;list-style:none;margin:24px 0;font-size:15px;color:#0a0a0a">
              {['Tudo do plano.solo', '4x mentoria 1:1', 'Review de PR direto comigo', 'Discord priority channel', 'Acesso a proxima turma de graca'].map((item) => (
                <li style="padding:6px 0;display:flex;gap:12px"><span style="color:var(--lime-500)">+</span><span>{item}</span></li>
              ))}
            </ul>
            <a class="btn btn-primary btn-lg" href="#pricing" style="background:#0a0a0a;color:var(--fg);width:100%;justify-content:center">Garantir vaga PRO &rarr;</a>
          </div>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
