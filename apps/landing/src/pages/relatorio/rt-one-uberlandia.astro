    <!-- Interactivity -->
    <script is:inline>
      // Theme toggle
      (function () {
        var btn = document.getElementById('rto-theme-btn');
        if (!btn) return;
        function sync() {
          var isDark = document.documentElement.classList.contains('dark');
          btn.textContent = isDark ? 'Claro' : 'Escuro';
        }
        sync();
        btn.addEventListener('click', function () {
          var nextDark = !document.documentElement.classList.contains('dark');
          document.documentElement.classList.toggle('dark', nextDark);
          try {
            localStorage.setItem('rto-dark', nextDark ? '1' : '0');
          } catch (e) {}
          sync();
        });
      })();
    </script>

    <script is:inline>
      // Energy comparator
      (function () {
        var slider = document.getElementById('rto-power-slider');
        if (!slider) return;
        var mwReadout = document.getElementById('rto-mw-readout');
        var gwhEl = document.getElementById('rto-gwh');
        var mwhEl = document.getElementById('rto-mwh');
        var housesEl = document.getElementById('rto-houses');
        var vsIndustryEl = document.getElementById('rto-vs-industry');
        var perSquareEl = document.getElementById('rto-per-square');
        var grid = document.getElementById('rto-houses-grid');
        var cells = grid ? Array.prototype.slice.call(grid.children) : [];
        var TOTAL = cells.length;
        var INDUSTRY_DAILY = 547808 / 365;

        function fmt(n) { return n.toLocaleString('pt-BR'); }
        function fmt2(n) { return n.toFixed(2).replace('.', ','); }

        function update() {
          var mw = parseInt(slider.value, 10);
          var gwh = (mw * 24) / 1000;
          var mwh = mw * 24;
          var houses = Math.round((mwh * 1000) / 6);
          var vsInd = mwh / INDUSTRY_DAILY;
          var on = Math.round((mw / 400) * TOTAL);
          var perSq = Math.round(houses / TOTAL);

          if (mwReadout) mwReadout.textContent = mw;
          if (gwhEl) gwhEl.textContent = fmt2(gwh);
          if (mwhEl) mwhEl.textContent = fmt(mwh);
          if (housesEl) housesEl.textContent = fmt(houses);
          if (vsIndustryEl) vsIndustryEl.textContent = fmt2(vsInd) + '×';
          if (perSquareEl) perSquareEl.textContent = fmt(perSq);

          for (var i = 0; i < TOTAL; i++) {
            if (i < on) {
              if (!cells[i].classList.contains('on')) cells[i].classList.add('on');
            } else {
              if (cells[i].classList.contains('on')) cells[i].classList.remove('on');
            }
          }
        }

        slider.addEventListener('input', update);
        slider.addEventListener('change', update);
      })();
    </script>

    <script is:inline>
      // Timeline picker
      (function () {
        var track = document.getElementById('rto-timeline-track');
        var detail = document.getElementById('rto-timeline-detail');
        if (!track || !detail) return;
        var items = Array.prototype.slice.call(track.querySelectorAll('.t-item'));
        var panels = Array.prototype.slice.call(detail.querySelectorAll('.t-detail-panel'));

        function activate(idx) {
          items.forEach(function (el, i) {
            var on = i === idx;
            el.classList.toggle('active', on);
            el.setAttribute('aria-selected', on ? 'true' : 'false');
          });
          panels.forEach(function (el, i) {
            if (i === idx) el.removeAttribute('hidden');
            else el.setAttribute('hidden', '');
          });
        }

        items.forEach(function (el) {
          el.addEventListener('click', function () {
            var idx = parseInt(el.getAttribute('data-idx'), 10);
            if (!isNaN(idx)) activate(idx);
          });
        });

        // Scroll active item to center on mount
        var initial = items.findIndex(function (el) { return el.classList.contains('active'); });
        if (initial >= 0 && items[initial]) {
          try {
            items[initial].scrollIntoView({ behavior: 'instant', block: 'nearest', inline: 'center' });
          } catch (e) {
            items[initial].scrollIntoView({ block: 'nearest', inline: 'center' });
          }
        }
      })();
    </script>
