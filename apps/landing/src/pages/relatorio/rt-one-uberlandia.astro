---
import SEO from '../../components/SEO.astro';
import { RTO_DATA, RTO_DATA_EXTRA, RTO_TLDR, RTO_FAQ } from '../../data/rtone-report';
import '../../styles/relatorio-rtone/styles.css';
import '../../styles/relatorio-rtone/styles-impacts.css';

const pub = RTO_DATA.publication;
const hero = RTO_DATA.hero;
const stats = RTO_DATA.stats;
const water = RTO_DATA.water;
const energy = RTO_DATA.energy;
const impacts = RTO_DATA.impacts;
const licensing = RTO_DATA.licensing;
const timeline = RTO_DATA.timeline;
const profile = RTO_DATA_EXTRA.profile;
const hearing = RTO_DATA_EXTRA.hearing;
const national = RTO_DATA_EXTRA.national;
const recommendations = RTO_DATA_EXTRA.recommendations;
const caveats = RTO_DATA_EXTRA.caveats;
const sources = RTO_DATA_EXTRA.sources;

const fmt = (n: number) => n.toLocaleString('pt-BR');

const waterMaxV = Math.max(...water.table.map((r) => r.v));

// initial energy values @ 100 MW
const INITIAL_MW = 100;
const TOTAL_CELLS = 600;
const initialGwhPerDay = ((INITIAL_MW * 24) / 1000).toFixed(2).replace('.', ',');
const initialMwhPerDay = fmt(INITIAL_MW * 24);
const initialHouses = Math.round((INITIAL_MW * 24 * 1000) / 6);
const initialVsIndustry = (((INITIAL_MW * 24) / (547808 / 365))).toFixed(2).replace('.', ',');
const initialOn = Math.round((INITIAL_MW / 400) * TOTAL_CELLS);
const initialPerSquare = Math.round(initialHouses / TOTAL_CELLS);

const initialTimelineActive = timeline.length - 2; // MPF inquérito (index 10 of 12)

const description =
  'Anatomia do projeto RT-One em Uberlândia: R$ 6 bi, 100→400 MW, zero licença ambiental. Longread interativo com comparador de energia, cronologia regulatória, mapa nacional e impactos no entorno.';

const canonical = '/relatorio/rt-one-uberlandia';
const publishedTime = '2026-05-09T23:59:00-03:00';

const SITE = 'https://datacenteruberlandia.com.br';
const pageUrl = `${SITE}${canonical}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ReportageNewsArticle',
    headline: 'RT-One Uberlândia — Anatomia de um data center que ainda não existe',
    description,
    datePublished: publishedTime,
    dateModified: publishedTime,
    inLanguage: 'pt-BR',
    isAccessibleForFree: true,
    articleSection: 'Relatório especial / Monitoramento ambiental',
    keywords: 'RT-One, Uberlândia, data center, Aquífero Guarani, MPF, licenciamento ambiental, Cemig, DMAE, MGC-497',
    about: {
      '@type': 'Place',
      name: 'Uberlândia, Minas Gerais, Brasil',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Uberlândia',
        addressRegion: 'MG',
        addressCountry: 'BR',
      },
    },
    author: { '@type': 'Organization', name: 'Data Center Uberlândia', url: SITE },
    publisher: {
      '@type': 'Organization',
      name: 'Data Center Uberlândia',
      logo: { '@type': 'ImageObject', url: `${SITE}/og-default.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE}/` },
      { '@type': 'ListItem', position: 2, name: 'Diretório', item: `${SITE}/diretorio` },
      { '@type': 'ListItem', position: 3, name: 'RT-One Uberlândia', item: `${SITE}/diretorio/rt-one-uberlandia` },
      { '@type': 'ListItem', position: 4, name: 'Relatório', item: pageUrl },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: RTO_FAQ.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Cronologia regulatória — RT-One Uberlândia',
    numberOfItems: timeline.length,
    itemListOrder: 'https://schema.org/ItemListOrderAscending',
    itemListElement: timeline.map((t, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `${t.date} — ${t.title}`,
      description: t.body,
    })),
  },
];
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RT-One Uberlândia — Anatomia de um Data Center | Data Center Uberlândia</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700;8..60,800&family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <SEO
      title="RT-One Uberlândia — Anatomia de um Data Center"
      description={description}
      canonical={canonical}
      type="article"
      publishedTime={publishedTime}
      modifiedTime={publishedTime}
      articleSection="Relatório especial / Monitoramento ambiental"
      keywords={["RT-One", "Uberlândia", "data center", "Aquífero Guarani", "MPF", "licenciamento ambiental"]}
      author={{ name: 'Data Center Uberlândia', url: 'https://datacenteruberlandia.com.br' }}
      jsonLd={jsonLd}
    />
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('rto-dark');
          var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var dark = stored != null ? stored === '1' : prefersDark;
          if (dark) document.documentElement.classList.add('dark');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- Masthead -->
    <header class="masthead">
      <div class="wrap masthead-inner">
        <div class="masthead-meta">
          <span>{pub.edition}</span>
          <time datetime="2026-05-09">{pub.issued}</time>
        </div>
        <div class="masthead-title">Data Center Uberlândia</div>
        <div class="masthead-right">
          <a
            href="/"
            class="toc-btn"
            style="text-decoration: none;"
            aria-label="Voltar para a home"
          >← Site</a>
          <button class="theme-btn" type="button" id="rto-theme-btn">Escuro</button>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero hairline-bottom-strong">
      <div class="wrap">
        <nav class="eyebrow" aria-label="Breadcrumb" style="margin-bottom: 18px;">
          <a href="/" style="text-decoration: none; color: inherit;">Home</a>
          <span style="margin: 0 8px; opacity: 0.5;">›</span>
          <a href="/diretorio" style="text-decoration: none; color: inherit;">Diretório</a>
          <span style="margin: 0 8px; opacity: 0.5;">›</span>
          <a href="/diretorio/rt-one-uberlandia" style="text-decoration: none; color: inherit;">RT-One Uberlândia</a>
          <span style="margin: 0 8px; opacity: 0.5;">›</span>
          <span aria-current="page" style="color: var(--ink);">Relatório</span>
        </nav>
        <div class="eyebrow" style="margin-bottom: 28px;">{hero.kicker}</div>
        <h1 class="hero-headline">
          {hero.headlinePre} <em>{hero.headlineItalic}</em>.
        </h1>
        <p class="hero-dek" style="margin-top: 36px;">{hero.dek}</p>

        <div class="bylines">
          {hero.byline.map((b) => (
            <div class="byline">
              <div class="byline-label">{b.label}</div>
              <div class="byline-value">{b.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- TL;DR — extractable answer block for AI overviews -->
    <aside
      class="rto-tldr"
      aria-label="Resposta direta"
      style="border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink); background: var(--paper-2); padding: 28px 0;"
    >
      <div class="wrap" style="display: grid; grid-template-columns: 200px 1fr; gap: 40px; align-items: start;">
        <div>
          <div class="eyebrow">Resposta direta</div>
          <div style="margin-top: 8px; font-family: var(--mono); font-size: 11px; color: var(--ink-4); letter-spacing: 0.12em; text-transform: uppercase;">
            Atualizado em <time datetime="2026-05-09">09.05.2026</time>
          </div>
        </div>
        <p style="font-family: var(--serif); font-size: 19px; line-height: 1.55; color: var(--ink); max-width: 780px; margin: 0;">
          {RTO_TLDR}
        </p>
      </div>
    </aside>

    <!-- Stat row -->
    <section class="stat-row" aria-label="Números-chave">
      {stats.map((s) => (
        <div class={`stat-cell ${s.alert ? 'alert' : ''}`}>
          <span class="label">{s.label}</span>
          <div class="value">
            {s.value}
            {s.sup && <sup>{s.sup}</sup>}
            {s.unit && (
              <span style="font-family: var(--mono); font-size: 0.32em; margin-left: 10px; color: var(--ink-3); letter-spacing: 0.08em;">{s.unit}</span>
            )}
          </div>
          <div class="caption">{s.caption}</div>
        </div>
      ))}
    </section>

    <!-- I — Water -->
    <section class="section" id="agua">
      <div class="wrap">
        <div class="section-head">
          <div class="section-num">
            Seção <strong>I</strong>
            <div style="margin-top: 14px;"><span class="section-tag tag-water">Água</span></div>
          </div>
          <div>
            <h2 class="section-title">{water.title}</h2>
            <p class="section-lead">{water.lead}</p>
          </div>
        </div>

        <div class="prose col">
          {water.paragraphs.map((p) => (
            <p class={p.dropcap ? 'dropcap' : ''} set:html={p.text} />
          ))}
        </div>

        <div class="col-wide water-grid">
          <div class="water-stat">
            <div class="num">239,3<span style="font-size: 0.45em; margin-left: 8px;">mil</span></div>
            <div class="unit" style="margin-top: 8px;">Litros / dia — fase 1</div>
            <div class="desc">Vazão máxima solicitada à concessionária local. Aprovação técnica do DMAE em fev/2026, com base no argumento de que o pedido não entraria no rol dos dez maiores consumidores da cidade.</div>
          </div>

          <table class="compare-table">
            <thead>
              <tr>
                <th style="width: 44%;">Comparativo</th>
                <th>Vazão</th>
                <th style="width: 28%;"></th>
              </tr>
            </thead>
            <tbody>
              {water.table.map((r) => (
                <tr>
                  <td>
                    <div style="font-size: 14px;">{r.label}</div>
                    <div style="font-family: var(--mono); font-size: 10.5px; color: var(--ink-4); margin-top: 4px; letter-spacing: 0.08em; text-transform: uppercase;">{r.note}</div>
                  </td>
                  <td class="num">
                    {fmt(r.v)}
                    <div style="font-family: var(--mono); font-size: 10px; color: var(--ink-4);">{r.unit}</div>
                  </td>
                  <td class="barcell">
                    <span class="bar" style={`width: ${Math.sqrt(r.v / waterMaxV) * 100}%;`} />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="col-wide" style="margin: 32px auto 0;">
          <blockquote class="pullquote col">
            “{water.quote.text}”
            <cite>— {water.quote.who}</cite>
          </blockquote>
          <div class="callout col">
            <div class="callout-label">{water.callout.label}</div>
            <p set:html={water.callout.text} />
          </div>
        </div>
      </div>
    </section>

    <!-- II — Energy -->
    <section class="section" id="energia">
      <div class="wrap">
        <div class="section-head">
          <div class="section-num">
            Seção <strong>II</strong>
            <div style="margin-top: 14px;"><span class="section-tag tag-energy">Energia</span></div>
          </div>
          <div>
            <h2 class="section-title">{energy.title}</h2>
            <p class="section-lead">{energy.lead}</p>
          </div>
        </div>

        <div class="prose col">
          {energy.paragraphs.map((p) => (
            <p set:html={p.text} />
          ))}
        </div>

        <div class="col-wide">
          <div class="energy-comparator">
            <div class="eyebrow" style="margin-bottom: 6px;">Comparador interativo</div>
            <div style="font-family: var(--serif); font-size: 22px; font-weight: 600; margin-bottom: 4px;">
              Demanda contratada: <span style="color: var(--energy);" id="rto-mw-readout">{INITIAL_MW}</span> MW
            </div>
            <div style="font-size: 13px; color: var(--ink-3); margin-bottom: 14px;">
              Arraste para simular a expansão de 100 (fase 1) a 400 MW (capacidade declarada).
            </div>

            <div class="slider-row">
              <span class="lbl">100</span>
              <input
                type="range"
                min="100"
                max="400"
                step="10"
                value={INITIAL_MW}
                class="power-slider"
                id="rto-power-slider"
                aria-label="Potência em MW"
              />
              <span class="lbl">400</span>
            </div>

            <div class="energy-readouts">
              <div class="cell">
                <div class="lbl">Consumo diário</div>
                <div><span class="v" id="rto-gwh">{initialGwhPerDay}</span><span class="u">GWh / dia</span></div>
                <div class="sub"><span id="rto-mwh">{initialMwhPerDay}</span> MWh em 24 h, operação contínua.</div>
              </div>
              <div class="cell">
                <div class="lbl">Equivale a</div>
                <div><span class="v" id="rto-houses">{fmt(initialHouses)}</span><span class="u">residências</span></div>
                <div class="sub">A 6 kWh/dia por casa (média EPE, mar/2025).</div>
              </div>
              <div class="cell">
                <div class="lbl">vs. indústria de Uberlândia</div>
                <div><span class="v" id="rto-vs-industry">{initialVsIndustry}×</span><span class="u">setor inteiro</span></div>
                <div class="sub">Setor industrial inteiro consumiu 547 808 MWh em 2020.</div>
              </div>
            </div>

            <div class="houses-viz">
              <div style="font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-4); margin-bottom: 10px;">
                Cada quadrado = <span id="rto-per-square">{fmt(initialPerSquare)}</span> residências brasileiras
              </div>
              <div class="houses-grid" id="rto-houses-grid">
                {Array.from({ length: TOTAL_CELLS }).map((_, i) => (
                  <div class={`house ${i < initialOn ? 'on' : ''}`} />
                ))}
              </div>
            </div>
          </div>

          <blockquote class="pullquote col">
            “Para o Brasil ser de fato protagonista na transição energética, precisamos atrair demanda de indústrias intensivas em energia renovável. Precisamos incentivar data centers a virem para o Brasil. Claro que os data centers têm que vir para cá.”
            <cite>— Reynaldo Passanezi Filho — CEO da Cemig, seminário Energia para o Futuro, jan/2026</cite>
          </blockquote>

          <div class="callout col">
            <div class="callout-label">Ressalva da Cemig ao MPF</div>
            <p set:html={'A própria Cemig registrou que <strong>“o impacto de desabastecimento energético ou hídrico em nível nacional não é de sua responsabilidade”</strong> — frase destacada por críticos como concessão tácita de risco sistêmico.'} />
          </div>
        </div>
      </div>
    </section>

    <!-- III — Impacts -->
    <section class="section section-impacts" id="impactos">
      <div class="wrap">
        <div class="section-head">
          <div class="section-num">
            Seção <strong>III</strong>
            <div style="margin-top: 14px;"><span class="section-tag tag-alert">Impactos no entorno</span></div>
          </div>
          <div>
            <h2 class="section-title">{impacts.title}</h2>
            <p class="section-lead">{impacts.lead}</p>
          </div>
        </div>

        <div class="col-wide">
          <div class="neighbors">
            <div class="nlabel">Comunidades vizinhas — MGC-497</div>
            <div class="nrow">
              {impacts.neighborhoods.map((n, i) => (
                <span style="display: inline-flex; align-items: baseline;">
                  {i > 0 && <span class="ndot">/</span>}
                  <span class="nname">{n.name}</span>
                  <span class="nnote">{n.note}</span>
                </span>
              ))}
            </div>
          </div>

          {impacts.items.map((item) => (
            <article class="impact-card">
              <div class="impact-head">
                <div class="impact-n">{item.n}</div>
                <div>
                  <span class="impact-cat">{item.kicker}</span>
                  <h3 class="impact-headline">{item.headline}</h3>
                </div>
              </div>

              <p class="impact-lead">{item.lead}</p>

              {item.decibels && (
                <div class="db-scale">
                  <div class="db-row" style="border-bottom: 1px solid var(--ink);">
                    <div class="name" style="font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4);">Fonte</div>
                    <div class="db-bar-track" style="background: transparent; border: none; height: 18px; position: relative;">
                      {[0, 20, 40, 60, 80, 100].map((t) => (
                        <div style={`position: absolute; left: ${t}%; top: 0; bottom: 0; ${t === 0 ? '' : 'border-left: 1px solid var(--rule-2);'} padding-left: 6px; font-family: var(--mono); font-size: 10px; color: var(--ink-4); letter-spacing: 0.06em;`}>
                          {t} dB
                        </div>
                      ))}
                    </div>
                    <div class="num" style="font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-4);">Nível</div>
                  </div>
                  {item.decibels.map((r) => (
                    <div class="db-row">
                      <div class={`name ${r.kind}`}>{r.label}</div>
                      <div class="db-bar-track">
                        <div class={`db-bar-fill ${r.kind}`} style={`width: ${(r.db / 100) * 100}%;`} />
                      </div>
                      <div class="num">{r.db}<small>dB</small></div>
                    </div>
                  ))}
                </div>
              )}

              {item.bars && (
                <div class="stress-grid">
                  {item.bars.map((b) => {
                    const pct = (b.v / b.max) * 100;
                    const cls = pct >= 90 ? 'crit' : pct >= 70 ? 'warn' : '';
                    return (
                      <div class="stress-row">
                        <div class="name">
                          {b.label}
                          <small>{b.note}</small>
                        </div>
                        <div class="num">
                          {fmt(b.v)}
                          <small>{b.unit}</small>
                        </div>
                        <div class="stress-track">
                          <div class={`stress-fill ${cls}`} style={`width: ${pct}%;`} />
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}

              {item.ladder && (
                <div class="ladder">
                  {item.ladder.map((r, i) => (
                    <div class="rung" data-color={['verde', 'amarela', 'vermelha-1', 'vermelha-2'][i]}>
                      <div class="flag" />
                      <div class="nm">{r.label}</div>
                      <div class="pct">+{r.pct}% encargo</div>
                      <div class="nt">{r.note}</div>
                    </div>
                  ))}
                </div>
              )}

              {item.meta && (
                <div class="obra-strip">
                  {item.meta.map((m) => (
                    <div class="obra-cell">
                      <div class="lbl">{m.lbl}</div>
                      <div class="v">{m.v}</div>
                    </div>
                  ))}
                </div>
              )}

              {item.n === '05' && (
                <div class="conv-card">
                  <div>
                    <div class="lbl">Convenção 169</div>
                    <div class="title">OIT · 1989</div>
                  </div>
                  <div class="body">
                    <strong style="color: var(--paper);">Consulta prévia, livre e informada.</strong>{' '}
                    A Convenção 169 da OIT, ratificada pelo Brasil, garante a comunidades tradicionais e locais o direito de serem consultadas antes de qualquer empreendimento que as afete. A consulta é condição de legitimidade — não etapa burocrática a cumprir depois.
                  </div>
                </div>
              )}

              <div class="impact-body">
                <div>
                  <div class="lbl">Mecanismo</div>
                  <p>{item.mechanism}</p>
                </div>
                <div>
                  <div class="lbl">Evidência</div>
                  <p>{item.evidence}</p>
                </div>
              </div>

              <div class="impact-source">Fontes — {item.source}</div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- IV — Licensing -->
    <section class="section" id="licenciamento">
      <div class="wrap">
        <div class="section-head">
          <div class="section-num">
            Seção <strong>IV</strong>
            <div style="margin-top: 14px;"><span class="section-tag tag-legal">Licenciamento</span></div>
          </div>
          <div>
            <h2 class="section-title">{licensing.title}</h2>
            <p class="section-lead">{licensing.lead}</p>
          </div>
        </div>

        <div class="col-wide">
          <div class="license-grid">
            {licensing.cards.map((c) => (
              <div class="license-card">
                <span class="stamp">Pendente</span>
                <div class="code">{c.code}</div>
                <div class="name">{c.name}</div>
                <div class="status">{c.status}</div>
                <div class="body">{c.body}</div>
              </div>
            ))}
          </div>

          <div class="callout col">
            <div class="callout-label">{licensing.callout.label}</div>
            <p set:html={licensing.callout.text} />
          </div>
        </div>
      </div>
    </section>

    <!-- V — Timeline -->
    <section class="section" id="cronologia">
      <div class="wrap">
        <div class="section-head">
          <div class="section-num">
            Seção <strong>V</strong>
            <div style="margin-top: 14px;"><span class="section-tag tag-alert">Cronologia regulatória</span></div>
          </div>
          <div>
            <h2 class="section-title">Doze marcos entre 2024 e 2026.</h2>
            <p class="section-lead">Da fundação da empresa em dezembro de 2024 até o protocolo aguardado na Semad/FEAM em maio. Clique em qualquer evento.</p>
          </div>
        </div>

        <div class="timeline">
          <div class="timeline-track" id="rto-timeline-track">
            {timeline.map((t, i) => (
              <button
                type="button"
                class={`t-item ${i === initialTimelineActive ? 'active' : ''}`}
                data-idx={i}
                aria-selected={i === initialTimelineActive ? 'true' : 'false'}
              >
                <div class="date">{t.date}</div>
                <div class="ttl">{t.title}</div>
