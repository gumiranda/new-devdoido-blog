---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = (await getCollection('comparar')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Comparativos de Data Centers"
  description="Comparativos lado a lado entre projetos de data centers no Brasil: RT-One, TikTok, Scala AI City, Elea. Capacidade, licenciamento, consumo de água e energia."
  canonical="/comparar"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://datacenteruberlandia.com.br/' },
      { '@type': 'ListItem', position: 2, name: 'Comparar', item: 'https://datacenteruberlandia.com.br/comparar' },
    ],
  }}
>
  <section class="relative overflow-hidden bg-gradient-to-br from-primary/5 via-base-100 to-secondary/5 border-b border-base-300">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,oklch(var(--p)/0.08),transparent_50%)] pointer-events-none" aria-hidden="true"></div>
    <div class="container relative mx-auto px-4 py-12 md:py-16 max-w-4xl">
      <a href="/" class="inline-flex items-center gap-1.5 text-base-content/70 hover:text-primary text-sm mb-6 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Home
      </a>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-3">
        <span class="title-shimmer bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">Comparativos</span>
      </h1>
      <p class="text-base-content/75 max-w-2xl">
        Comparações lado a lado entre projetos de data centers no Brasil: RT-One, TikTok, Scala AI City, Elea e mais. Capacidade, status ambiental, consumo de recursos e controvérsias.
      </p>
    </div>
  </section>

  <div class="container mx-auto px-4 py-10 md:py-14 max-w-3xl">
    <ul class="space-y-5" role="list">
      {comparisons.map((comp) => (
        <li>
          <a
            href={`/comparar/${comp.slug}`}
            class="group block rounded-xl border border-base-300 bg-base-200/80 shadow-md hover:shadow-xl hover:border-primary/30 transition-all duration-200 overflow-hidden"
          >
            <div class="card-body gap-2 p-5 md:p-6">
              <div class="flex items-start justify-between gap-4">
                <h2 class="card-title text-xl md:text-2xl font-bold text-base-content group-hover:text-primary transition-colors">
                  {comp.data.title}
                </h2>
                <span class="shrink-0 flex h-8 w-8 items-center justify-center rounded-lg bg-primary/15 text-primary group-hover:bg-primary/25 transition-colors" aria-hidden="true">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </span>
              </div>
              <p class="text-base-content/75 text-sm md:text-base leading-relaxed">
                {comp.data.description}
              </p>
              <div class="flex flex-wrap items-center gap-3 text-xs text-base-content/50 font-mono">
                <span>{comp.data.cityA}/{comp.data.stateA}</span>
                <span>vs</span>
                <span>{comp.data.cityB}/{comp.data.stateB}</span>
                <span>·</span>
                <time datetime={comp.data.pubDate.toISOString()}>
                  {comp.data.pubDate.toLocaleDateString('pt-BR', { dateStyle: 'medium' })}
                </time>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>

    {comparisons.length === 0 && (
      <p class="text-center text-base-content/60 py-12">Nenhum comparativo publicado ainda.</p>
    )}
  </div>
</BaseLayout>
