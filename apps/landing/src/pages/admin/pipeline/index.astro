---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Pipeline YouTube" description="Pipeline de transcrição YouTube do CrazyStack." canonical="/admin/pipeline" noindex>
  <div class="app">

    <!-- SIDEBAR -->
    <aside class="app-sidebar">
      <div class="sb-brand"><span class="mark">&gt;_</span> devdoido<span class="caret"></span></div>
      <div class="sb-tenant" id="tenant-switch">
        <div class="tlogo">DD</div>
        <div class="tinfo"><b>DEVDOIDO</b><span>workspace · blog</span></div>
      </div>

      <nav class="sb-nav">
        <div class="sb-group">
          <div class="glabel">Conteudo</div>
          <div class="sb-item" data-nav="artigos">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Artigos
          </div>
        </div>

        <div class="sb-group">
          <div class="glabel">Pipeline YouTube</div>
          <div class="sb-item active" data-nav="overview">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Visao geral
          </div>
          <div class="sb-item" data-nav="channels">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
            Canais
          </div>
          <div class="sb-item" data-nav="schedule">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Agendamento
          </div>
          <div class="sb-item" data-nav="runs">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Execucoes
          </div>
          <div class="sb-item" data-nav="library">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            Biblioteca
          </div>
        </div>
      </nav>

      <div class="sb-foot">
        <div class="sb-user">
          <div class="av">GM</div>
          <div class="ui"><b>Gustavo Miranda</b><span>founder · devdoido</span></div>
        </div>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="app-main">
      <div class="app-topbar">
        <div class="tb-crumb">
          <a href="/admin/editor" style="color:var(--fg-muted)">admin</a><span class="sep">/</span><span class="here" id="crumb-view">visao geral</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <a href="/admin/editor" class="btn btn-ghost btn-sm">Editor</a>
          <a href="/admin/transcribe" class="btn btn-ghost btn-sm">Transcricao</a>
          <a href="/" class="btn btn-secondary btn-sm">← Site</a>
          <div class="app-status" id="conn-status">
            <span class="dot off" id="conn-dot"></span>
            <span id="conn-text">Conta Google nao conectada</span>
          </div>
        </div>
      </div>

      <div style="flex:1;overflow-y:auto">

        <!-- OVERVIEW -->
        <section class="view active" data-view="overview">
          <div id="ov-disconnected">
            <h1 class="page-title">Pipeline de <span style="color:var(--lime-400);font-style:normal">YouTube</span></h1>
            <p class="page-desc">Monitore canais do YouTube, busque os videos mais recentes automaticamente e transcreva tudo em texto.</p>

            <div class="connect-hero">
              <div class="ch-icons">
                <div class="ch-icon cs"><svg fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg></div>
                <span class="ch-conn">&lt;—&gt;</span>
                <div class="ch-icon yt"><svg fill="currentColor" viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8zM9.5 15.5v-7l6.5 3.5z"/></svg></div>
              </div>
              <h2>Conecte uma conta Google para comecar</h2>
              <p>Para consultar a YouTube Data API precisamos de uma conta Google autorizada.</p>
              <button class="btn btn-primary btn-lg" id="connect-btn"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Conectar conta Google</button>
            </div>
          </div>

          <div id="ov-connected" style="display:none">
            <h1 class="page-title">Visao geral</h1>
            <p class="page-desc" style="margin:0 0 28px">Pipeline ativo. Proxima execucao automatica agendada.</p>

            <div class="grid-4" style="margin-bottom:18px">
              <div class="stat-tile"><div class="st-top"><div class="st-ic"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg></div></div><b>3</b><span>canais monitorados</span></div>
              <div class="stat-tile"><div class="st-top"><div class="st-ic"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div><span class="st-delta">+6 hoje</span></div><b>128</b><span>videos transcritos</span></div>
              <div class="stat-tile"><div class="st-top"><div class="st-ic"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></div></div><b>42</b><span>execucoes</span></div>
              <div class="stat-tile"><div class="st-top"><div class="st-ic"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div></div><b>32%</b><span>quota usada hoje</span></div>
            </div>
          </div>
        </section>

        <!-- CHANNELS -->
        <section class="view" data-view="channels">
          <div class="list-head">
            <div>
              <h1 class="page-title" style="margin-bottom:6px">Canais monitorados</h1>
              <p class="page-desc" style="margin:0">Os canais cujos uploads mais recentes serao consultados a cada execucao.</p>
            </div>
            <button class="btn btn-primary"><svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Adicionar canal</button>
          </div>

          {[
            { name:'Rocketseat', color:'linear-gradient(135deg,#8257e6,#6420aa)', letter:'R', handle:'@rocketseat', subs:'2.1M', last:'capturado hoje'},
            { name:'Filipe Deschamps', color:'linear-gradient(135deg,#06b6d4,#0e7490)', letter:'F', handle:'@FilipeDeschamps', subs:'1.6M', last:'capturado hoje'},
            { name:'Codigo Fonte TV', color:'linear-gradient(135deg,#f59e0b,#b45309)', letter:'C', handle:'@codigofontetv', subs:'1.2M', last:'capturado ontem'},
          ].map((ch) => (
            <div class="chan-row">
              <div class="chan-av" style={`background:${ch.color}`}>{ch.letter}</div>
              <div class="chan-meta"><b>{ch.name}</b><div class="handle">{ch.handle}</div></div>
              <div class="chan-stat"><b>{ch.subs}</b><span>inscritos</span></div>
              <div class="chan-last">ultimo video<br /><span class="ok">{ch.last}</span></div>
              <div class="switch on"></div>
            </div>
          ))}
        </section>

        <!-- SCHEDULE -->
        <section class="view" data-view="schedule">
          <h1 class="page-title">Agendamento</h1>
          <p class="page-desc">Defina quando e com que frequencia o pipeline busca e transcreve novos videos.</p>
          <div class="sched-grid">
            <div class="card card-pad">
              <div class="field"><label>Frequencia</label>
                <div class="seg" id="freq-seg"><button class="active">Diaria</button><button>A cada 6 horas</button><button>Semanal</button></div>
              </div>
              <div class="field"><label>Horario da execucao</label>
                <input class="input mono" type="time" id="time-input" value="08:00" style="max-width:160px" />
                <div class="hint">A cron diaria roda neste horario, no fuso configurado abaixo.</div>
              </div>
              <div class="field"><label>Fuso horario</label>
                <select class="input mono"><option selected>America/Sao_Paulo (BRT, UTC-3)</option></select>
              </div>
              <div class="divider"></div>
              <div class="field"><label>O que fazer em cada execucao</label>
                <div class="check-opt on" data-check><div class="check-box"><svg fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="co-text"><b>Buscar videos recentes</b><span>Consulta os uploads via YouTube Data API.</span></div></div>
                <div class="check-opt on" data-check><div class="check-box"><svg fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="co-text"><b>Transcrever audio em texto</b><span>Gera a transcricao completa.</span></div></div>
                <div class="check-opt on" data-check><div class="check-box"><svg fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></div><div class="co-text"><b>Salvar no banco de dados</b><span>Persiste metadados + transcricao.</span></div></div>
              </div>
              <div style="display:flex;gap:10px;margin-top:28px">
                <button class="btn btn-primary">Salvar agendamento</button>
                <button class="btn btn-secondary">Cancelar</button>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:18px">
              <div class="next-run">
                <div class="nr-lbl">// proxima execucao</div>
                <div class="nr-time">Amanha, 08:00</div>
                <div class="nr-rel">diariamente · America/Sao_Paulo</div>
                <div class="nr-steps">
                  <div class="nr-step"><span class="n">01</span> Consultar uploads recentes de 3 canais</div>
                  <div class="nr-step"><span class="n">02</span> Filtrar videos das ultimas 24h</div>
                  <div class="nr-step"><span class="n">03</span> Transcrever audio em texto</div>
                  <div class="nr-step"><span class="n">04</span> Salvar transcricoes no banco</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- RUNS -->
        <section class="view" data-view="runs">
          <div class="list-head">
            <div><h1 class="page-title" style="margin-bottom:6px">Execucoes</h1><p class="page-desc" style="margin:0">Historico de cada rodada do pipeline.</p></div>
          </div>
          <div class="run-row head"><span>quando</span><span>status</span><span>canais</span><span>videos novos</span><span>transcritos</span><span>duracao</span><span></span></div>
          {[
            { when:'hoje 08:00', date:'29 mai', status:'ok', chans:'3', news:'6', done:'6', dur:'2:14' },
            { when:'ontem 08:00', date:'28 mai', status:'ok', chans:'3', news:'4', done:'4', dur:'1:52' },
            { when:'27 mai 08:00', date:'27 mai', status:'err', chans:'3', news:'5', done:'3', dur:'3:40' },
            { when:'26 mai 08:00', date:'26 mai', status:'ok', chans:'3', news:'2', done:'2', dur:'1:08' },
            { when:'25 mai 08:00', date:'25 mai', status:'ok', chans:'3', news:'3', done:'3', dur:'1:36' },
          ].map((r) => (
            <div class="run-row">
              <div class="run-when"><b>{r.when}</b><span>{r.date} 2026</span></div>
              <span class={`run-status ${r.status}`}>{r.status==='ok'?'sucesso':'erro parcial'}</span>
              <div class="run-metric">{r.chans} <span>canais</span></div>
              <div class="run-metric">{r.news} <span>novos</span></div>
              <div class="run-metric">{r.done} <span>ok</span></div>
              <div class="run-metric">{r.dur}</div>
              <span style="color:var(--fg-dim)">→</span>
            </div>
          ))}
        </section>

        <!-- LIBRARY -->
        <section class="view" data-view="library">
          <h1 class="page-title">Biblioteca de transcricoes</h1>
          <p class="page-desc">Videos capturados e transcritos, salvos no banco.</p>
          <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px" id="lib-filters">
            <span class="fchip active" data-f="all">Todos</span>
            <span class="fchip" data-f="rocketseat">Rocketseat</span>
            <span class="fchip" data-f="filipe">Filipe Deschamps</span>
            <span class="fchip" data-f="codigo">Codigo Fonte TV</span>
          </div>
          <div class="grid-3" id="vid-grid"></div>
        </section>

      </div>
    </div>
  </div>
</BaseLayout>

<script>
  (function(){
    var views = ['overview','channels','schedule','runs','library'];
    var titles = { overview:'visao geral', channels:'canais monitorados', schedule:'agendamento', runs:'execucoes', library:'biblioteca' };
    var connected = false;

    function navTo(v){
      document.querySelectorAll('.sb-item').forEach(function(i){ i.classList.toggle('active', i.getAttribute('data-nav')===v); });
      document.querySelectorAll('.view').forEach(function(vw){ vw.classList.toggle('active', vw.getAttribute('data-view')===v); });
      document.getElementById('crumb-view').textContent = titles[v] || v;
    }
    document.querySelectorAll('.sb-item').forEach(function(i){
      i.addEventListener('click', function(){ var v = i.getAttribute('data-nav'); if(v&&views.includes(v)) navTo(v); });
    });

    function applyConnected(){
      document.getElementById('conn-dot').className = 'dot '+(connected?'ok':'off');
      document.getElementById('conn-text').textContent = connected ? 'devdoido.bot@gmail.com' : 'Conta Google nao conectada';
      document.getElementById('ov-disconnected').style.display = connected ? 'none' : 'block';
      document.getElementById('ov-connected').style.display = connected ? 'block' : 'none';
    }

    document.getElementById('connect-btn').addEventListener('click', function(){
      connected = true; applyConnected();
      navTo('channels');
    });

    // Schedule check toggles
    document.querySelectorAll('[data-check]').forEach(function(c){
      c.addEventListener('click', function(){ c.classList.toggle('on'); });
    });

    // Library
    var videos = [
      { ch:'rocketseat', chName:'Rocketseat', col:'#8257e6,#3b0d6b', letter:'R', title:'Next.js 16: o que muda na pratica', dur:'18:24', pub:'29 mai', words:'3.412', grad:'linear-gradient(135deg,#8257e6,#3b0d6b)' },
      { ch:'rocketseat', chName:'Rocketseat', col:'#8257e6,#3b0d6b', letter:'R', title:'Turborepo em monorepos', dur:'24:10', pub:'28 mai', words:'4.108', grad:'linear-gradient(135deg,#7c3aed,#4c1d95)' },
      { ch:'filipe', chName:'Filipe Deschamps', col:'#06b6d4,#0e7490', letter:'F', title:'Sistema de filas do zero', dur:'41:52', pub:'29 mai', words:'7.220', grad:'linear-gradient(135deg,#06b6d4,#0c4a6e)' },
      { ch:'codigo', chName:'Codigo Fonte TV', col:'#f59e0b,#b45309', letter:'C', title:'Clean Architecture de verdade', dur:'15:30', pub:'28 mai', words:'2.890', grad:'linear-gradient(135deg,#f59e0b,#92400e)' },
      { ch:'rocketseat', chName:'Rocketseat', col:'#8257e6,#3b0d6b', letter:'R', title:'React Server Components', dur:'21:08', pub:'27 mai', words:'3.940', grad:'linear-gradient(135deg,#6d28d9,#4c1d95)' },
      { ch:'filipe', chName:'Filipe Deschamps', col:'#06b6d4,#0e7490', letter:'F', title:'Postgres indices que voce nao usa', dur:'33:14', pub:'27 mai', words:'6.012', grad:'linear-gradient(135deg,#0891b2,#0c4a6e)' },
    ];

    function renderLib(f){
      var list = videos.filter(function(v){ return !f||f==='all'||v.ch===f; });
      document.getElementById('vid-grid').innerHTML = list.map(function(v){
        return '<div style="background:var(--bg-1);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden;cursor:pointer;transition:all .22s">'
          + '<div style="aspect-ratio:16/9;position:relative;display:flex;align-items:center;justify-content:center;background:'+v.grad+'">'
          + '<div style="width:48px;height:48px;border-radius:50%;background:rgba(0,0,0,.55);display:flex;align-items:center;justify-content:center"><svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24" style="color:#fff;margin-left:2px"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>'
          + '<span style="position:absolute;bottom:8px;right:8px;font-family:var(--f-mono);font-size:10px;background:rgba(0,0,0,.8);color:#fff;padding:2px 6px;border-radius:3px">'+v.dur+'</span>'
          + '<span style="position:absolute;top:8px;left:8px;font-family:var(--f-mono);font-size:10px;padding:3px 8px;border-radius:3px;background:hsl(83 81% 44% / .85);color:#0a0a0a">transcrito</span></div>'
          + '<div style="padding:16px">'
          + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:10px"><span style="width:20px;height:20px;border-radius:50%;background:linear-gradient(135deg,'+v.col+');color:#fff;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700">'+v.letter+'</span><span class="mono-caption" style="font-size:11px">'+v.chName+'</span></div>'
          + '<h4 style="margin:0 0 10px;font-size:14px;font-weight:600;line-height:1.35">'+v.title+'</h4>'
          + '<div style="display:flex;justify-content:space-between;font-family:var(--f-mono);font-size:10px;color:var(--fg-dim)"><span>'+v.pub+' 2026</span><span>'+v.words+' palavras</span></div>'
          + '</div></div>';
      }).join('');
    }

    document.getElementById('lib-filters').addEventListener('click', function(e){
      var c = e.target.closest('.fchip'); if(!c) return;
      document.querySelectorAll('#lib-filters .fchip').forEach(function(x){ x.classList.remove('active'); });
      c.classList.add('active');
      renderLib(c.getAttribute('data-f'));
    });
    renderLib('all');

    document.querySelectorAll('.switch').forEach(function(sw){
      sw.addEventListener('click', function(){ sw.classList.toggle('on'); });
    });

    applyConnected();
  })();
</script>
