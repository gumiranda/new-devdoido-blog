---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageShell from '../components/devdoido/PageShell.astro';
import TypeStage from '../components/devdoido/TypeStage.astro';
---

<BaseLayout title="Pagina nao encontrada" description="Essa rota nao existe no DEVDOIDO." noindex={true}>
  <PageShell active="Home">
    <section class="section" style="padding-top:32px">
      <div class="container">
        <div class="tile tile-hero" style="padding:0;justify-content:flex-end">
          <TypeStage word="404" density={0.18} />
          <div style="position:relative;z-index:1;padding:48px">
            <span class="badge badge-sale">rota quebrada</span>
            <h1 class="t-display" style="margin-top:24px">404.<br />Sem stacktrace.</h1>
            <p class="tile-sub">Essa pagina sumiu, nunca existiu, ou foi vibe-coded por alguem com pressa.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap">
              <a class="btn" href="/">Voltar pra home</a>
              <a class="btn btn-secondary" href="/blog">Ver blog</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </PageShell>
</BaseLayout>
