---
import SEO from '../components/SEO.astro';
import { SITE } from '../data/devdoido';
import '../styles/devdoido.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  image?: string;
  articleSection?: string;
  keywords?: string[];
  author?: {
    name: string;
    url?: string;
    credentials?: string;
    sameAs?: string[];
  };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  noindex,
  type = 'website',
  publishedTime,
  modifiedTime,
  image,
  articleSection,
  keywords,
  author,
  jsonLd,
} = Astro.props;
const fullTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.title}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="DEVDOIDO RSS" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&family=Geist+Mono:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      image={image}
      articleSection={articleSection}
      keywords={keywords}
      author={author}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Pular para conteudo</a>
    <slot />
  </body>
</html>
