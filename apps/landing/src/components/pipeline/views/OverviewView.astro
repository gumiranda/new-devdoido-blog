<script>
  (function() {
    function update() {
      const connected = localStorage.getItem('pipeline-connected') === 'true';
      document.getElementById('ov-disconnected')!.style.display = connected ? 'none' : 'block';
      document.getElementById('ov-connected')!.style.display = connected ? 'block' : 'none';
    }
    update();
    window.addEventListener('pipeline-connection-changed', update);
    document.getElementById('open-oauth')?.addEventListener('click', () => window.openOauth());
  })();
</script>
