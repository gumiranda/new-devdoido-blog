---

<aside class="sidebar">
  <div class="sb-brand"><span class="mark">&gt;_</span> devdoido<span class="caret"></span></div>

  <div class="sb-tenant" id="tenant-switch">
    <div class="tlogo">DD</div>
    <div class="tinfo"><b>DEVDOIDO</b><span>workspace · blog</span></div>
    <span class="chev"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></span>
  </div>

  <nav class="sb-nav">
    {LINKS.map((group) => (
      <div class="sb-group">
        <div class="glabel">{group.group}</div>
        {group.items.map((item) => (
          <a
            href={item.href}
            class:list={['sb-item', currentPage === item.id ? 'active' : '']}
          >
            <Fragment set:html={ICONS[item.id] ?? ''} />
            {item.label}
          </a>
        ))}
      </div>
    ))}
  </nav>

  <div class="sb-foot">
    <div class="sb-user">
      <div class="av">GM</div>
      <div class="ui"><b>Gustavo Miranda</b><span>founder · devdoido</span></div>
    </div>
  </div>
</aside>
