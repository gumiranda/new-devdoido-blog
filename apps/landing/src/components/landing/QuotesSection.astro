---
import Icon from './Icon.astro';

const quotes = [
  {
    text: '100 mil pessoas moram em áreas irregulares, sem acesso a água, energia e saneamento básico. Como serão direcionados esses recursos para o data center, enquanto as pessoas estão sem energia e água em casa?',
    source: 'Vereador Dr. Igino (PT) — Audiência pública, 26/03/2026',
    type: 'critical',
  },
  {
    text: 'Ele não é COO da Intel Corporation e nunca ocupou esse cargo.',
    source: 'Intel — Nota oficial ao Aos Fatos sobre Fernando Palamone, CEO da RT-One',
    type: 'scandal',
  },
  {
    text: 'Não existe data center sustentável.',
    source: 'Vereadora Amanda Gondim (PSB) — Audiência pública, 26/03/2026',
    type: 'critical',
  },
  {
    text: 'O impacto de desabastecimento energético ou hídrico em nível nacional não é de nossa responsabilidade.',
    source: 'Cemig — Resposta ao MPF no inquérito civil',
    type: 'alert',
  },
  {
    text: 'Consumirá menos do que um conjunto habitacional de 300 casas. E em uma área que não tem qualquer problema ambiental.',
    source: 'Prefeito Paulo Sérgio (PP) — 23/02/2026',
    type: 'defense',
  },
  {
    text: 'Todo o aquífero poderá ser afetado.',
    source: 'Ata da Comissão de Direitos Humanos da Câmara — 26/03/2026',
    type: 'alert',
  },
  {
    text: 'Sou contra o data center e vou lutar para que o empreendimento vá para outro lugar.',
    source: 'Vereador Dr. Igino (PT) — Audiência pública, 26/03/2026',
    type: 'critical',
  },
];

const cardClass = (type: string) =>
  type === 'scandal'
    ? 'bg-dc-destructive/10 border-dc-destructive/50'
    : type === 'critical'
      ? 'bg-dc-accent/10 border-dc-accent/50'
      : type === 'alert'
        ? 'bg-dc-primary/10 border-dc-primary/50'
        : type === 'popular'
          ? 'bg-dc-secondary/50 border-dc-secondary'
          : 'bg-dc-card border-dc-border';

const quoteIconClass = (type: string) =>
  type === 'scandal'
    ? 'text-dc-destructive/30'
    : type === 'critical'
      ? 'text-dc-accent/30'
      : 'text-dc-primary/30';
---
<section class="py-24 px-4 bg-dc-card/30">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-4">
        O QUE <span class="text-dc-accent">DISSERAM</span>
      </h2>
      <p class="text-dc-muted-fg text-lg">
        Citações reais de documentos oficiais e reportagens.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {quotes.map((quote) => (
        <blockquote class={`relative rounded-lg p-6 border ${cardClass(quote.type)}`}>
          <span class={`absolute top-4 right-4 ${quoteIconClass(quote.type)}`}>
            <Icon name="quote" size={24} />
          </span>
          <p class={`text-lg leading-relaxed mb-4 ${quote.type === 'popular' ? 'font-black text-2xl' : ''}`}>
            &ldquo;{quote.text}&rdquo;
          </p>
          <footer class="text-sm text-dc-muted-fg font-mono">
            — {quote.source}
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>
