---
import Icon from './Icon.astro';

const demands = [
  {
    number: '01',
    title: 'Coordenadas públicas AGORA',
    description:
      'Divulgação imediata do polígono georreferenciado do terreno, matrícula do imóvel e memorial descritivo. Não é possível fiscalizar o que não se pode localizar.',
  },
  {
    number: '02',
    title: 'Explicar a contradição hídrica',
    description:
      "Detalhar por que prometeram 'zero água para refrigeração' e depois pediram 2,77 L/s ao DMAE. E se vão captar do aquífero como em Maringá?",
  },
  {
    number: '03',
    title: 'EIA/RIMA com audiência pública',
    description:
      'Empreendimento de R$ 6 bi e 400 MW exige EIA/RIMA completo, não Relatório Ambiental Simplificado. MPF-CE já condenou essa prática em Caucaia.',
  },
  {
    number: '04',
    title: 'Responder ao MPF',
    description:
      'RT-One NÃO respondeu ao inquérito civil. Exigimos que a empresa se manifeste oficialmente sobre as acusações de uso indevido do nome da Intel.',
  },
  {
    number: '05',
    title: 'Inventário de fauna e flora',
    description:
      'Diagnóstico completo da APP de 300 mil m². Lobo-guará, tamanduá-bandeira e raposinha-do-campo circulam na MGC-497. Precisamos de dados reais.',
  },
  {
    number: '06',
    title: 'Contratos de energia verificáveis',
    description:
      "Prova documental de 100% energia renovável com adicionalidade. A Cemig admitiu que 'desabastecimento nacional não é sua responsabilidade'.",
  },
  {
    number: '07',
    title: 'Consulta prévia às comunidades',
    description:
      'Convenção 169 da OIT garante consulta prévia, livre e informada às comunidades de Chácaras Douradinho, Pequis e Monte Hebrom.',
  },
  {
    number: '08',
    title: 'Prefeitura e RT-One nas audiências',
    description:
      'Na audiência de 26/03/2026, NENHUM DOS DOIS compareceu. Exigimos presença e respostas em debates públicos.',
  },
];

const sources = [
  { name: 'Aos Fatos', url: 'https://www.aosfatos.org' },
  { name: 'Jornal O Futuro', url: '#' },
  { name: 'Câmara de Uberlândia', url: 'https://www.camarauberlandia.mg.gov.br' },
  { name: 'Prefeitura de Uberlândia', url: 'https://www.uberlandia.mg.gov.br' },
  { name: 'MPF', url: 'https://www.mpf.mp.br' },
  { name: 'UFU', url: 'https://www.ufu.br' },
  { name: 'Instituto Trata Brasil', url: 'https://www.tratabrasil.org.br' },
];
---
<section class="py-24 px-4 bg-dc-card/30">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-4">
        O QUE <span class="text-dc-primary">EXIGIMOS</span>
      </h2>
      <p class="text-dc-muted-fg text-lg max-w-2xl mx-auto">
        Transparência não é favor. É obrigação legal e moral.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-16">
      {demands.map((demand) => (
        <div class="group flex gap-4 p-6 bg-dc-bg border border-dc-border rounded-lg hover:border-dc-primary/50 transition-colors">
          <span class="text-4xl font-black text-dc-primary/30 group-hover:text-dc-primary transition-colors">
            {demand.number}
          </span>
          <div>
            <h3 class="text-lg font-bold mb-2">{demand.title}</h3>
            <p class="text-sm text-dc-muted-fg">{demand.description}</p>
          </div>
        </div>
      ))}
    </div>

    {/* Sources */}
    <div class="border-t border-dc-border pt-12">
      <h3 class="text-sm font-mono text-dc-muted-fg mb-6 text-center">
        FONTES CONSULTADAS
      </h3>
      <div class="flex flex-wrap justify-center gap-4">
        {sources.map((source) => (
          <a
            href={source.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-dc-card border border-dc-border rounded-full text-sm hover:border-dc-primary/50 transition-colors"
          >
            <span class="font-medium">{source.name}</span>
            <Icon name="external-link" size={12} class="text-dc-muted-fg" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
