---
const timelineEvents = [
  {
    date: 'DEZ 2024',
    title: 'RT-One é criada',
    description:
      'Empresa registrada em São Paulo, Vila Ipojuca — mesmo endereço da antiga importadora Gamernuc de Fernando Palamone.',
    type: 'alert',
  },
  {
    date: 'AGO 2024',
    title: 'Escândalo Intel',
    description:
      "Fernando Palamone assina carta de intenções com GDF se apresentando como COO/VP da Intel. Intel nega: 'Ele nunca ocupou esse cargo'. RT-One diz 'não ter conhecimento'.",
    type: 'scandal',
  },
  {
    date: 'JAN 2025',
    title: 'Anúncio em Maringá (PR)',
    description:
      'Primeiro projeto anunciado. R$ 6 bi, 400 MW. Admitem publicamente possibilidade de captar água do Aquífero Guarani.',
    type: 'announcement',
  },
  {
    date: '08/07/2025',
    title: 'Anúncio em Uberlândia',
    description:
      "Segundo projeto: 'maior data center da América Latina'. 1 milhão de m² na MGC-497. Promessa de 2 mil empregos.",
    type: 'announcement',
  },
  {
    date: '09/09/2025',
    title: 'Aquisição do terreno',
    description:
      'Cerimônia com prefeito Paulo Sérgio (PP), vice Vanderley Pelizer, secretário Fabiano Alves. Grande festa.',
    type: 'announcement',
  },
  {
    date: '24/09/2025',
    title: "Promessas 'verdes'",
    description:
      "Divulgação de APP interna (300 mil m²), energia 100% renovável, 'zero consumo de água para refrigeração'.",
    type: 'claim',
  },
  {
    date: '17/03/2026',
    title: 'Aos Fatos investiga',
    description:
      'Reportagem revela inquérito civil do MPF e o histórico falsificado de Palamone na Intel. RT-One não responde ao MPF.',
    type: 'scandal',
  },
  {
    date: '18/03/2026',
    title: 'Ranking Trata Brasil',
    description:
      'Uberlândia cai 10 posições em saneamento (11ª para 21ª). Pior resultado da história. Investimento: R$ 69,89/hab (recomendado: R$ 225).',
    type: 'context',
  },
  {
    date: '23/02/2026',
    title: 'A contradição hídrica',
    description:
      "Prefeitura informa pedido de 2,77 L/s de água ao DMAE. São 239 mil litros/dia. Cadê o 'zero água'?",
    type: 'contradiction',
  },
  {
    date: '26/03/2026',
    title: 'Audiência pública',
    description:
      'Câmara Municipal realiza audiência. NEM A PREFEITURA NEM O CEO DA RT-ONE COMPARECEM. Enviaram apenas um advogado.',
    type: 'scandal',
  },
  {
    date: 'MAR 2026',
    title: 'Marco normativo UFU',
    description:
      'Estudantes de Direito da UFU propõem lei municipal para regular data centers. Entregue à vereadora Amanda Gondim.',
    type: 'resistance',
  },
  {
    date: '2026',
    title: 'PENDENTE',
    description:
      'Licenciamento ambiental estadual na SEMAD/FEAM-MG. Nenhuma licença emitida até maio/2026.',
    type: 'pending',
  },
  {
    date: '2026',
    title: 'PENDENTE',
    description:
      'Autorização ONS para conexão à rede básica do SIN. Cemig aprovou apenas tecnicamente.',
    type: 'pending',
  },
  {
    date: '???',
    title: 'NUNCA DIVULGADO',
    description:
      'Coordenadas geográficas, polígono georreferenciado, EIA/RIMA, contratos com Cemig, plano de contingência hídrica.',
    type: 'missing',
  },
];

const dotClass = (type: string) =>
  type === 'scandal'
    ? 'bg-dc-destructive'
    : type === 'contradiction' || type === 'missing'
      ? 'bg-dc-accent'
      : type === 'pending'
        ? 'bg-dc-muted-fg'
        : type === 'claim'
          ? 'bg-dc-primary'
          : type === 'resistance'
            ? 'bg-green-500'
            : type === 'alert'
              ? 'bg-yellow-500'
              : 'bg-dc-fg';

const badgeClass = (type: string) =>
  type === 'scandal'
    ? 'bg-dc-destructive/20 text-dc-destructive'
    : type === 'contradiction' || type === 'missing'
      ? 'bg-dc-accent/20 text-dc-accent'
      : type === 'pending'
        ? 'bg-dc-muted text-dc-muted-fg'
        : type === 'claim'
          ? 'bg-dc-primary/20 text-dc-primary'
          : type === 'resistance'
            ? 'bg-green-500/20 text-green-500'
            : 'bg-dc-secondary text-dc-secondary-fg';

const titleClass = (type: string) =>
  type === 'scandal'
    ? 'text-dc-destructive'
    : type === 'contradiction' || type === 'missing'
      ? 'text-dc-accent'
      : type === 'pending'
        ? 'text-dc-muted-fg'
        : type === 'resistance'
          ? 'text-green-500'
          : '';
---
<section class="py-24 px-4 bg-dc-card/30">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-4">
        LINHA DO <span class="text-dc-primary">TEMPO</span>
      </h2>
      <p class="text-dc-muted-fg text-lg max-w-2xl mx-auto">
        O que foi dito, quando foi dito, e o que ainda falta.
      </p>
    </div>

    <div class="relative">
      {/* Vertical line */}
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-dc-border md:-translate-x-1/2"></div>

      {timelineEvents.map((event, index) => (
        <div
          class={`relative flex items-start gap-6 mb-6 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}
        >
          {/* Dot */}
          <div class={`absolute left-0 md:left-1/2 w-3 h-3 rounded-full md:-translate-x-1/2 ${dotClass(event.type)}`}></div>

          {/* Content */}
          <div class={`ml-8 md:ml-0 md:w-1/2 ${index % 2 === 0 ? 'md:pr-12 md:text-right' : 'md:pl-12'}`}>
            <div class={`inline-block px-3 py-1 text-xs font-mono rounded mb-2 ${badgeClass(event.type)}`}>
              {event.date}
            </div>
            <h3 class={`text-lg font-bold mb-1 ${titleClass(event.type)}`}>
              {event.title}
            </h3>
            <p class="text-sm text-dc-muted-fg">
              {event.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
