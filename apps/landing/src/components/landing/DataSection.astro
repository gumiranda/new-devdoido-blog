---
const impactData = [
  {
    component: 'ÁGUA',
    phase: 'Operação',
    impact:
      'Demanda hídrica de 2,77 L/s (239 mil L/dia); pressão em período seco; possível captação subterrânea como em Maringá',
    magnitude: 'ALTA',
    probability: 'ALTA',
    uncertainty: 'ALTA',
  },
  {
    component: 'SOLO E DRENAGEM',
    phase: 'Implantação',
    impact:
      'Terraplenagem de 1 milhão m², impermeabilização extensa, erosão e assoreamento se houver APP/vereda',
    magnitude: 'ALTA',
    probability: 'ALTA',
    uncertainty: 'ALTA',
  },
  {
    component: 'AR, ENERGIA, RUÍDO',
    phase: 'Operação',
    impact:
      '134.900 t CO₂/ano indireto (400 MW); ruído técnico; rejeição térmica; geradores diesel de backup',
    magnitude: 'ALTA',
    probability: 'ALTA',
    uncertainty: 'MÉDIA',
  },
  {
    component: 'BIODIVERSIDADE',
    phase: 'Todas',
    impact:
      'Efeito de borda em APP de 300 mil m², barreira à fauna, supressão de habitats no corredor MGC-497',
    magnitude: 'ALTA',
    probability: 'MÉDIA',
    uncertainty: 'ALTA',
  },
  {
    component: 'SOCIOECONÔMICO',
    phase: 'Todas',
    impact: 'Promessa de 2 mil empregos vs. 100 mil pessoas sem água/energia em áreas irregulares',
    magnitude: 'MÉDIA',
    probability: 'ALTA',
    uncertainty: 'ALTA',
  },
];

const faunaAtRisk = [
  { name: 'Lobo-guará', status: 'AMEAÇADO' },
  { name: 'Tamanduá-bandeira', status: 'AMEAÇADO' },
  { name: 'Raposinha-do-campo', status: 'AMEAÇADO' },
];

const comparisons = [
  {
    name: 'TikTok / Caucaia (CE)',
    capacity: '210-576 MW',
    issue:
      "Licenciado por RAS. MPF-CE: 'inadequado, insuficiente e inadmissível'. Água: 144 mil L/dia (7,3× o declarado). Território ancestral Anace.",
    status: 'CONTESTADO',
  },
  {
    name: 'RT-One / Maringá (PR)',
    capacity: '400 MW',
    issue: 'ADMITE uso do Aquífero Guarani. ZPE federal pendente. Investigado pelo MPF-PR.',
    status: 'INVESTIGADO',
  },
  {
    name: 'Scala AI City / Eldorado do Sul (RS)',
    capacity: '1.800-5.000 MW',
    issue: 'Ainda em licenciamento. Resfriamento a óleo em circuito fechado.',
    status: 'PENDENTE',
  },
];

const magnitudeClass = (v: string) =>
  v === 'ALTA' ? 'bg-dc-accent/20 text-dc-accent' : 'bg-dc-primary/20 text-dc-primary';

const probabilityClass = (v: string) =>
  v === 'ALTA' ? 'bg-dc-accent/20 text-dc-accent' : 'bg-dc-muted text-dc-muted-fg';

const uncertaintyClass = (v: string) =>
  v === 'ALTA' ? 'bg-dc-destructive/20 text-dc-destructive' : 'bg-dc-muted text-dc-muted-fg';

const statusClass = (s: string) =>
  s === 'CONTESTADO'
    ? 'bg-dc-destructive/20 text-dc-destructive'
    : s === 'INVESTIGADO'
      ? 'bg-dc-accent/20 text-dc-accent'
      : 'bg-dc-muted text-dc-muted-fg';
---
<section class="py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-black tracking-tight mb-4">
        MATRIZ DE <span class="text-dc-accent">IMPACTOS</span>
      </h2>
      <p class="text-dc-muted-fg text-lg max-w-2xl mx-auto">
        Análise técnica baseada em documentos públicos, estudos da UFU e reportagens.
      </p>
    </div>

    {/* Impact table: cards on small screens, full table from md */}
    <div class="md:hidden space-y-4 mb-16">
      {impactData.map((row) => (
        <article class="rounded-xl border border-dc-border bg-dc-card/40 p-4">
          <div class="mb-3 flex flex-wrap items-baseline justify-between gap-2 border-b border-dc-border/50 pb-3">
            <h3 class="text-sm font-bold tracking-wide">{row.component}</h3>
            <span class="text-xs font-mono text-dc-muted-fg">{row.phase}</span>
          </div>
          <p class="mb-4 text-sm leading-relaxed text-dc-muted-fg">
            <span class="mb-1 block text-xs font-mono text-dc-muted-fg/80">IMPACTO PRINCIPAL</span>
            {row.impact}
          </p>
          <div class="flex flex-wrap gap-2">
            <span class={`inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-mono ${magnitudeClass(row.magnitude)}`}>
              <span class="text-dc-muted-fg/80">MAG.</span> {row.magnitude}
            </span>
            <span class={`inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-mono ${probabilityClass(row.probability)}`}>
              <span class="text-dc-muted-fg/80">PROB.</span> {row.probability}
            </span>
            <span class={`inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-mono ${uncertaintyClass(row.uncertainty)}`}>
              <span class="text-dc-muted-fg/80">INCERT.</span> {row.uncertainty}
            </span>
          </div>
        </article>
      ))}
    </div>

    <div class="hidden md:block overflow-x-auto mb-16">
      <table class="w-full min-w-[640px] text-sm">
        <thead>
          <tr class="border-b border-dc-border">
            <th class="text-left py-4 px-4 font-mono text-dc-muted-fg">COMPONENTE</th>
            <th class="text-left py-4 px-4 font-mono text-dc-muted-fg">FASE</th>
            <th class="min-w-[14rem] text-left py-4 px-4 font-mono text-dc-muted-fg">IMPACTO PRINCIPAL</th>
            <th class="text-center py-4 px-4 font-mono text-dc-muted-fg">MAG.</th>
            <th class="text-center py-4 px-4 font-mono text-dc-muted-fg">PROB.</th>
            <th class="text-center py-4 px-4 font-mono text-dc-muted-fg">INCERT.</th>
          </tr>
        </thead>
        <tbody>
          {impactData.map((row) => (
            <tr class="border-b border-dc-border/50 hover:bg-dc-card/50 transition-colors">
              <td class="py-4 px-4 font-bold">{row.component}</td>
              <td class="py-4 px-4 text-dc-muted-fg">{row.phase}</td>
              <td class="py-4 px-4 text-dc-muted-fg align-top">{row.impact}</td>
              <td class="py-4 px-4 text-center align-top">
                <span class={`px-2 py-1 rounded text-xs font-mono ${magnitudeClass(row.magnitude)}`}>
                  {row.magnitude}
                </span>
              </td>
              <td class="py-4 px-4 text-center align-top">
                <span class={`px-2 py-1 rounded text-xs font-mono ${probabilityClass(row.probability)}`}>
                  {row.probability}
                </span>
              </td>
              <td class="py-4 px-4 text-center align-top">
                <span class={`px-2 py-1 rounded text-xs font-mono ${uncertaintyClass(row.uncertainty)}`}>
                  {row.uncertainty}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    {/* Stats Grid */}
    <div class="grid md:grid-cols-4 gap-6 mb-16">
      <div class="bg-dc-card border border-dc-border rounded-lg p-6">
        <h3 class="text-sm font-mono text-dc-muted-fg mb-2">EMISSÕES CO₂ INDIRETAS/ANO</h3>
        <div class="text-4xl font-black text-dc-accent mb-2">134.900</div>
        <div class="text-sm text-dc-muted-fg">toneladas (cenário 400 MW)</div>
      </div>

      <div class="bg-dc-card border border-dc-border rounded-lg p-6">
        <h3 class="text-sm font-mono text-dc-muted-fg mb-2">CONSUMO ELÉTRICO/ANO</h3>
        <div class="text-4xl font-black text-dc-primary mb-2">3.504</div>
        <div class="text-sm text-dc-muted-fg">GWh (cenário 400 MW)</div>
      </div>

      <div class="bg-dc-card border border-dc-border rounded-lg p-6">
        <h3 class="text-sm font-mono text-dc-muted-fg mb-2">APP INTERNA DECLARADA</h3>
        <div class="text-4xl font-black text-dc-fg mb-2">300.000</div>
        <div class="text-sm text-dc-muted-fg">m² sem diagnóstico público</div>
      </div>

      <div class="bg-dc-card border border-dc-border rounded-lg p-6">
        <h3 class="text-sm font-mono text-dc-muted-fg mb-2">CONSUMO DE ÁGUA/ANO</h3>
        <div class="text-4xl font-black text-dc-destructive mb-2">87.300</div>
        <div class="text-sm text-dc-muted-fg">m³ (fase 1, só rede DMAE)</div>
      </div>
    </div>

    {/* Fauna Alert */}
    <div class="bg-dc-accent/5 border border-dc-accent/30 rounded-lg p-6 mb-16">
      <h3 class="text-xl font-bold mb-4 flex items-center gap-2">
        <span class="w-2 h-2 bg-dc-accent rounded-full animate-pulse"></span>
        FAUNA EM RISCO NO CORREDOR MGC-497
      </h3>
      <p class="text-dc-muted-fg mb-4">
        Pesquisa da UFU registrou 49 indivíduos de 16 espécies atropeladas na rodovia. Entre elas:
      </p>
      <div class="flex flex-wrap gap-4">
        {faunaAtRisk.map((animal) => (
          <div class="flex items-center gap-2 bg-dc-card px-4 py-2 rounded-lg border border-dc-border">
            <span class="font-bold">{animal.name}</span>
            <span class="text-xs font-mono text-dc-accent bg-dc-accent/20 px-2 py-0.5 rounded">
              {animal.status}
            </span>
          </div>
        ))}
      </div>
    </div>

    {/* Comparisons */}
    <div>
      <h3 class="text-2xl font-bold mb-6">COMPARAÇÃO: OUTROS DATA CENTERS NO BRASIL</h3>
      <div class="grid md:grid-cols-3 gap-6">
        {comparisons.map((dc) => (
          <div class="bg-dc-card border border-dc-border rounded-lg p-6">
            <div class="flex items-center justify-between mb-3">
              <h4 class="font-bold">{dc.name}</h4>
              <span class={`text-xs font-mono px-2 py-1 rounded ${statusClass(dc.status)}`}>
                {dc.status}
              </span>
            </div>
            <div class="text-2xl font-black text-dc-primary mb-2">{dc.capacity}</div>
            <p class="text-sm text-dc-muted-fg">{dc.issue}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
