---
interface Props {
  name?: string;
  credentials?: string;
  bio?: string;
  url?: string;
}

const { name = 'Equipe Data Center Uberlândia', credentials = 'Monitoramento Ambiental e Socioeconômico', bio, url = '/sobre' } = Astro.props;
---

<div class="mt-14 pt-10 border-t border-base-300/80">
  <p class="text-base-content/60 text-sm mb-3">Publicado por:</p>
  <div class="flex items-start gap-4">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary font-bold text-lg">
      {name.charAt(0)}
    </div>
    <div>
      <p class="font-semibold text-base-content">
        {url ? (
          <a href={url} class="hover:text-primary transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded">
            {name}
          </a>
        ) : (
          name
        )}
      </p>
      {credentials && <p class="text-sm text-primary">{credentials}</p>}
      {bio && <p class="text-sm text-base-content/70 mt-1">{bio}</p>}
    </div>
  </div>
</div>
