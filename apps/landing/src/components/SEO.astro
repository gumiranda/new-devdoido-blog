---
/**
 * SEO component: meta tags, Open Graph, Twitter, canonical, JSON-LD.
 * Use on every page for consistent SEO.
 */
interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  image?: string;
  articleSection?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  author?: {
    name: string;
    url?: string;
    credentials?: string;
    sameAs?: string[];
  };
}

const { title, description, canonical, noindex = false, type = 'website', publishedTime, modifiedTime, image, articleSection, keywords, jsonLd, author } = Astro.props;
const site = Astro.site?.href ?? 'https://datacenteruberlandia.com.br';
const url = canonical ? (canonical.startsWith('http') ? canonical : new URL(canonical, site).href) : Astro.url.href;
const fullTitle = title === 'Data Center Uberlândia' ? title : `${title} | Data Center Uberlândia`;
const ogImage = image ?? new URL('/og-default.png', site).href;
---

<!-- Primary meta -->
<meta name="description" content={description} />
{
  noindex
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
}
<link rel="canonical" href={url} />
<meta name="theme-color" content="#0f172a" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Data Center Uberlândia" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{type === 'article' && publishedTime && (
  <>
    <meta property="article:published_time" content={publishedTime} />
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  </>
)}

<!-- JSON-LD: WebSite or Article -->
{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Data Center Uberlândia',
      url: site,
      description: 'Blog independente que monitora e relata os impactos ambientais e socioeconômicos da instalação de data centers em Uberlândia (MG).',
      logo: new URL('/og-default.png', site).href,
      sameAs: [
        `${site}/sobre`,
        `${site}/blog`,
        `${site}/rss.xml`,
      ],
    },
    {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'Data Center Uberlândia',
      description: description,
      url: site,
      inLanguage: 'pt-BR',
      potentialAction: {
        '@type': 'SearchAction',
        target: `${site}blog?q={search_term_string}`,
        'query-input': 'required name=search_term_string',
      },
    },
  ])} />
)}
{type === 'article' && publishedTime && (
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: title,
    description: description,
    image: ogImage,
    url: url,
    datePublished: publishedTime,
    dateModified: modifiedTime ?? publishedTime,
    inLanguage: 'pt-BR',
    ...(articleSection ? { articleSection } : {}),
    ...(keywords ? { keywords: keywords.join(', ') } : {}),
    author: author ? {
      '@type': 'Person',
      name: author.name,
      ...(author.url ? { url: author.url } : {}),
      ...(author.credentials ? { jobTitle: author.credentials } : {}),
      ...(author.sameAs ? { sameAs: author.sameAs } : {}),
      worksFor: {
        '@type': 'Organization',
        name: 'Data Center Uberlândia',
        url: site,
      },
    } : {
      '@type': 'Organization',
      name: 'Data Center Uberlândia',
      url: site,
    },
    publisher: {
      '@type': 'Organization',
      name: 'Data Center Uberlândia',
        logo: {
          '@type': 'ImageObject',
          url: new URL('/og-default.png', site).href,
        },
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': url,
    },
  })} />
)}
{jsonLd && (
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
