---
import { SITE } from '../../data/devdoido';

interface Props {
  active?: string;
  admin?: boolean;
  noFooter?: boolean;
  breadcrumb?: { label: string; href?: string }[];
}

const { active = 'Home', admin = false, noFooter = false, breadcrumb = [] } = Astro.props;

const mainLinks = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Feed', href: '/feed' },
  { label: 'Vibe Coding', href: '/categoria/vibe-coding' },
  { label: 'Cursos', href: '/cursos/crazystack-typescript' },
  { label: 'Cadastrar SaaS', href: '/criar-saas' },
];

const adminLinks = [
  { label: 'Editor', href: '/admin/editor' },
  { label: 'Transcricao', href: '/admin/transcribe' },
  { label: 'Pipeline YT', href: '/admin/pipeline' },
];
---

<header class="site-header">
  {admin ? (
    <div class="promo-bar">
      <b>ADMIN</b> &nbsp;·&nbsp; devdoido.com.br/admin &nbsp;·&nbsp; @devdoido &nbsp;·&nbsp; 412 posts publicados &nbsp;·&nbsp; <a href="/" style="color:#0a0a0a;font-weight:700">← voltar ao site</a>
    </div>
  ) : (
    <div class="promo-bar">
      <b>DEVDOIDO</b> &nbsp;·&nbsp; Conteudo bruto sobre programacao, IA, SaaS e carreira dev &nbsp;·&nbsp; <a href="/feed">feed da comunidade →</a>
    </div>
  )}

  <nav class="primary-nav" aria-label={admin ? 'Admin' : 'Principal'}>
    <div class="inner">
      <a href="/" class="brand">
        <span class="mark">&gt;_</span> {SITE.name.toLowerCase()}<span class="caret"></span>
      </a>

      <div class="nav-links">
        {(admin ? adminLinks : mainLinks).map((link) => (
          <a
            href={link.href}
            aria-current={link.label === active ? 'page' : undefined}
            class:list={[link.label === active && 'active']}
          >
            {link.label}
          </a>
        ))}
      </div>

      <div class="nav-actions">
        {admin ? (
          <a href="/" class="btn btn-secondary btn-sm">← Site publico</a>
        ) : (
          <>
            <label class="search-pill" aria-label="Buscar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-3.5-3.5"></path>
              </svg>
              <input placeholder="buscar artigo, tag, autor..." />
              <span class="kbd">⌘K</span>
            </label>
            <a href="/sobre" class="btn btn-secondary btn-sm">Sobre</a>
          </>
        )}
      </div>

      <button class="mobile-menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div class="mobile-panel" data-mobile-panel>
        {(admin ? adminLinks : mainLinks).map((link) => (
          <a href={link.href} aria-current={link.label === active ? 'page' : undefined}>{link.label}</a>
        ))}
        {!admin && (
          <>
            <a href="/sobre">Sobre</a>
            <a href="/admin/editor">Admin</a>
          </>
        )}
      </div>
    </div>
  </nav>

  {admin && (
    <div class="admin-subnav">
      <div class="inner">
        {adminLinks.map((link) => (
          <a href={link.href} class:list={['admin-subnav-link', link.label === active && 'active']}>
            {link.label}
          </a>
        ))}
      </div>
    </div>
  )}
</header>

<div style="min-height:100vh">
  <main id="main-content" tabindex="-1">
    {breadcrumb.length > 0 && (
      <div style="border-bottom:1px solid var(--border);padding:10px 0">
        <nav class="page" style="display:flex;align-items:center;gap:8px;font-family:var(--f-mono);font-size:12px;color:var(--fg-muted);flex-wrap:wrap" aria-label="Breadcrumb">
          <a href="/" style="color:var(--fg-muted)">home</a>
          {breadcrumb.map((crumb, i) => (
            <>
              <span class="sep" style="color:var(--fg-dim)">/</span>
              {crumb.href ? (
                <a href={crumb.href} style="color:var(--fg-muted)">{crumb.label}</a>
              ) : (
                <span class="here" style="color:var(--lime-400)">{crumb.label}</span>
              )}
            </>
          ))}
        </nav>
      </div>
    )}
    <slot />
  </main>
</div>

{!noFooter && !admin && (
  <footer class="footer">
    <div class="inner">
      <div class="foot-grid">
        <div class="foot-col foot-brand">
          <a href="/" class="brand"><span class="mark">&gt;_</span> {SITE.name.toLowerCase()}</a>
          <p>Conteudo bruto sobre programacao, IA, vibe coding e carreira dev. Sem hype, sem promessa de virar senior em 6 meses.</p>
        </div>
        <div class="foot-col">
          <h4>Navegacao</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/blog">Blog · 412 artigos</a></li>
            <li><a href="/feed">Feed da comunidade</a></li>
            <li><a href="/categoria/vibe-coding">Vibe Coding</a></li>
          </ul>
        </div>
        <div class="foot-col">
          <h4>Produto</h4>
          <ul>
            <li><a href="/cursos/crazystack-typescript">CrazyStack TypeScript</a></li>
            <li><a href="/criar-saas">Cadastrar SaaS</a></li>
            <li><a href="/feed">Feed da comunidade</a></li>
            <li><a href="/sobre">Sobre</a></li>
          </ul>
        </div>
        <div class="foot-col">
          <h4>Comunidade</h4>
          <ul>
            <li><a href="https://youtube.com/@devdoido" rel="noreferrer">YouTube</a></li>
            <li><a href="https://x.com/devdoido" rel="noreferrer">X/twitter</a></li>
            <li><a href="/rss.xml">RSS feed</a></li>
          </ul>
        </div>
      </div>
      <div class="foot-bar">
        <span>// &copy; 2026 {SITE.name.toLowerCase()} &middot; feito no Brasil com Astro e opiniao demais</span>
        <span class="status">● build passing · last deploy 2026.05.29</span>
      </div>
    </div>
  </footer>
)}

{admin && (
  <footer style="border-top:1px solid var(--border);padding:32px 48px;display:flex;justify-content:space-between;gap:16px;align-items:center;font-family:var(--f-mono);font-size:11px;color:var(--fg-dim);flex-wrap:wrap">
    <span>// admin · {SITE.name.toLowerCase()} v.2026.05 &middot; <a href="/admin/editor" style="color:var(--lime-400)">editor</a> &middot; <a href="/admin/transcribe" style="color:var(--lime-400)">transcribe</a> &middot; <a href="/admin/pipeline" style="color:var(--lime-400)">pipeline</a></span>
    <span>whisper-large-v3 · claude-haiku-4-5 · mock local · <a href="/" style="color:var(--lime-400)">← site</a></span>
  </footer>
)}

<script>
  document.querySelectorAll('[data-menu-toggle]').forEach(function(button) {
    var nav = button.closest('nav');
    var panel = nav && nav.querySelector('[data-mobile-panel]');
    if (!panel) return;
    button.addEventListener('click', function() {
      var open = button.getAttribute('aria-expanded') !== 'true';
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.setAttribute('data-open', open ? 'true' : 'false');
    });
  });
</script>
