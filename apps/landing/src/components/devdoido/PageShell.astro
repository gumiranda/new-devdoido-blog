---
import { SITE } from '../../data/devdoido';

interface Props {
  active?: string;
  admin?: boolean;
  noFooter?: boolean;
}

const { active = 'Home', admin = false, noFooter = false } = Astro.props;
const links = [
  ['Home', '/'],
  ['Vibe Coding', '/categoria/vibe-coding'],
  ['IA', '/blog?tag=ia'],
  ['SaaS', '/blog?tag=saas'],
  ['Carreira', '/blog?tag=carreira'],
  ['Cursos', '/cursos/crazystack-typescript'],
] as const;
const adminLinks = ['Posts', 'Drafts', 'Transcribe', 'Stats', 'Subscribers', 'Settings'];
---

<div class="dd-page">
  <div class="dd-fx" aria-hidden="true"></div>
  <header class="site-header">
    <div class="utility-bar" style={admin ? 'background:var(--ink);color:var(--canvas)' : undefined}>
      <span>{admin ? '// admin · devdoido.com.br/admin' : '// devdoido.com.br · conteudo dev sem rodeio'}</span>
      <span class="utility-links">
        {admin ? (
          <span class="t-mono">@devdoido · session 4h 12m · 412 posts published</span>
        ) : (
          <>
            <a href="/rss.xml">RSS</a>
            <a href="https://x.com/devdoido" rel="noreferrer">X/twitter</a>
            <a href="https://youtube.com/@devdoido" rel="noreferrer">YouTube</a>
            <a href="/admin/transcribe">Entrar</a>
          </>
        )}
      </span>
    </div>

    <nav class="primary-nav" aria-label={admin ? 'Admin' : 'Principal'}>
      <a href="/" class="brand">
        <span class="brand-mark">DD</span>
        {SITE.name}{admin && <span class="t-mono muted" style="font-size:11px;margin-left:8px">/ ADMIN</span>}
      </a>

      {admin ? (
        <div class="nav-links">
          {adminLinks.map((link) => (
            <a href={link === 'Transcribe' ? '/admin/transcribe' : '#'} aria-current={link === active ? 'page' : undefined}>{link}</a>
          ))}
        </div>
      ) : (
        <div class="nav-links">
          {links.map(([label, href]) => (
            <a href={href} aria-current={label === active ? 'page' : undefined}>{label}</a>
          ))}
        </div>
      )}

      <div class="nav-actions">
        {admin ? (
          <a href="/" class="btn btn-secondary btn-sm">Voltar ao site</a>
        ) : (
          <>
            <label class="search-pill" aria-label="Buscar">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-3.5-3.5"></path>
              </svg>
              <input placeholder="busca por artigo, tag, autor..." />
              <span class="t-mono muted" style="font-size:11px">⌘K</span>
            </label>
            <a href="/newsletter" class="btn-icon" aria-label="Newsletter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M6 4h12v17l-6-4-6 4z"></path>
              </svg>
            </a>
            <a href="/sobre" class="btn-icon" aria-label="Sobre">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <circle cx="12" cy="8" r="4"></circle>
                <path d="M4 21c1.5-4.5 5-6 8-6s6.5 1.5 8 6"></path>
              </svg>
            </a>
          </>
        )}
      </div>

      <button class="btn-icon mobile-menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div class="mobile-panel" data-mobile-panel>
        {(admin ? adminLinks.map((label) => [label, label === 'Transcribe' ? '/admin/transcribe' : '#']) : links).map(([label, href]) => (
          <a href={href} aria-current={label === active ? 'page' : undefined}>{label}</a>
        ))}
      </div>
    </nav>
  </header>

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  {!noFooter && !admin && (
    <footer class="footer">
      <div style="margin-bottom:48px">
        <h2 class="t-display" style="font-size:120px;line-height:0.86">DEVDOIDO.<br />SEM RODEIO.</h2>
      </div>
      <div class="footer-grid">
        <div>
          <div style="display:flex;gap:8px;margin-bottom:18px;flex-wrap:wrap">
            <span class="badge">v.2026.05</span>
            <span class="badge badge-solid">+412 artigos</span>
          </div>
          <p class="t-caption" style="max-width:340px">
            Conteudo bruto sobre programacao, IA, vibe coding e universo dev. Sem hype, sem promessa de virar senior em 6 meses.
          </p>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-title">Conteudo</h3>
          <a href="/blog">Ultimos artigos</a>
          <a href="/blog">Mais lidos</a>
          <a href="/categoria/vibe-coding">Vibe coding</a>
          <a href="/blog?tag=ia">IA & agents</a>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-title">Cursos</h3>
          <a href="/cursos/crazystack-typescript">CrazyStack</a>
          <a href="/cursos/crazystack-typescript">Bun.js do zero</a>
          <a href="/cursos/crazystack-typescript">Claude Code Pro</a>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-title">Comunidade</h3>
          <a href="/newsletter">Newsletter</a>
          <a href="https://youtube.com/@devdoido" rel="noreferrer">YouTube</a>
          <a href="https://x.com/devdoido" rel="noreferrer">X/twitter</a>
          <a href="/rss.xml">RSS feed</a>
        </div>
        <div class="footer-col">
          <h3 class="footer-col-title">Sobre</h3>
          <a href="/sobre">Quem e o devdoido</a>
          <a href="/blog/pare-de-aprender-framework">Manifesto</a>
          <a href="/newsletter">Contato</a>
          <a href="/newsletter">Anuncie</a>
        </div>
      </div>
      <div class="footer-fine">
        <span>© 2026 devdoido · feito no Brasil, com Bun, Astro e opiniao demais.</span>
        <span>last build: 2026-05-15 14:22:08 UTC · 7ms · 412 posts</span>
      </div>
    </footer>
  )}

  {admin && (
    <footer style="border-top:1px solid var(--hairline);padding:32px;display:flex;justify-content:space-between;gap:16px;align-items:center;font-family:var(--font-mono);font-size:11px;color:var(--mute);flex-wrap:wrap">
      <span>// admin · devdoido v.2026.05 · build a8f3c2d</span>
      <span>whisper-large-v3 · claude-haiku-4-5 · mock local · 8 jobs/h limit</span>
    </footer>
  )}
</div>

<script>
  document.querySelectorAll('[data-menu-toggle]').forEach(function(button) {
    var nav = button.closest('nav');
    var panel = nav && nav.querySelector('[data-mobile-panel]');
    if (!panel) return;
    button.addEventListener('click', function() {
      var open = button.getAttribute('aria-expanded') !== 'true';
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.setAttribute('data-open', open ? 'true' : 'false');
    });
  });
</script>
