---
import { SITE } from '../../data/devdoido';

interface Props {
  active?: string;
  admin?: boolean;
  noFooter?: boolean;
}

const { active = 'Home', admin = false, noFooter = false } = Astro.props;
const links = [
  ['Home', '/'],
  ['Vibe Coding', '/categoria/vibe-coding'],
  ['IA', '/blog?tag=ia'],
  ['SaaS', '/blog?tag=saas'],
  ['Carreira', '/blog?tag=carreira'],
  ['Cursos', '/cursos/crazystack-typescript'],
] as const;
const adminLinks = ['Posts', 'Drafts', 'Transcribe', 'Stats', 'Subscribers', 'Settings'];
---

<header class="site-header">
  {admin ? (
    <div style="background:var(--lime-500);color:#0a0a0a;padding:6px 16px;text-align:center;font-family:var(--f-mono);font-size:11px;letter-spacing:.04em">
      // admin · devdoido.com.br/admin &nbsp;·&nbsp; @devdoido · session 4h 12m · 412 posts
    </div>
  ) : (
    <div class="promo-bar">
      <b>NEWSLETTER</b> &nbsp;·&nbsp; Toda quinta 6h &nbsp;·&nbsp; 3 links + 1 opiniao + 1 codigo<a href="/newsletter">assinar →</a>
    </div>
  )}

  <nav class="primary-nav" aria-label={admin ? 'Admin' : 'Principal'}>
    <div class="inner">
      <a href="/" class="brand">
        <span class="mark">&gt;_</span> {SITE.name.toLowerCase()}<span class="caret"></span>
      </a>

      {admin ? (
        <div class="nav-links">
          {adminLinks.map((link) => (
            <a href={link === 'Transcribe' ? '/admin/transcribe' : '#'} aria-current={link === active ? 'page' : undefined}>{link}</a>
          ))}
        </div>
      ) : (
        <div class="nav-links">
          {links.map(([label, href]) => (
            <a href={href} aria-current={label === active ? 'page' : undefined}>{label}</a>
          ))}
        </div>
      )}

      <div class="nav-actions">
        {admin ? (
          <a href="/" class="btn btn-secondary btn-sm">Voltar ao site</a>
        ) : (
          <>
            <label class="search-pill" aria-label="Buscar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="M20 20l-3.5-3.5"></path>
              </svg>
              <input placeholder="buscar artigo, tag, autor..." />
              <span class="kbd">⌘K</span>
            </label>
            <a href="/newsletter" class="btn btn-ghost btn-sm">Newsletter</a>
            <a href="/sobre" class="btn btn-secondary btn-sm">Sobre</a>
          </>
        )}
      </div>

      <button class="mobile-menu-toggle" type="button" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      <div class="mobile-panel" data-mobile-panel>
        {(admin ? adminLinks.map((label) => [label, label === 'Transcribe' ? '/admin/transcribe' : '#']) : links).map(([label, href]) => (
          <a href={href} aria-current={label === active ? 'page' : undefined}>{label}</a>
        ))}
      </div>
    </div>
  </nav>
</header>

<div style="min-height:100vh">
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
</div>

{!noFooter && !admin && (
  <footer class="footer">
    <div class="inner">
      <div class="foot-grid">
        <div class="foot-col foot-brand">
          <a href="/" class="brand"><span class="mark">&gt;_</span> {SITE.name.toLowerCase()}</a>
          <p>Conteudo bruto sobre programacao, IA, vibe coding e carreira dev. Sem hype, sem promessa de virar senior em 6 meses.</p>
        </div>
        <div class="foot-col">
          <h4>Conteudo</h4>
          <ul>
            <li><a href="/blog">Ultimos artigos</a></li>
            <li><a href="/blog">Mais lidos</a></li>
            <li><a href="/categoria/vibe-coding">Vibe coding</a></li>
            <li><a href="/blog?tag=ia">IA & agents</a></li>
          </ul>
        </div>
        <div class="foot-col">
          <h4>Cursos</h4>
          <ul>
            <li><a href="/cursos/crazystack-typescript">CrazyStack TypeScript</a></li>
            <li><a href="/cursos/crazystack-typescript">Bun.js do zero</a></li>
            <li><a href="/cursos/crazystack-typescript">Claude Code Pro</a></li>
          </ul>
        </div>
        <div class="foot-col">
          <h4>Comunidade</h4>
          <ul>
            <li><a href="/newsletter">Newsletter</a></li>
            <li><a href="https://youtube.com/@devdoido" rel="noreferrer">YouTube</a></li>
            <li><a href="https://x.com/devdoido" rel="noreferrer">X/twitter</a></li>
            <li><a href="/rss.xml">RSS feed</a></li>
          </ul>
        </div>
      </div>
      <div class="foot-bar">
        <span>// &copy; 2026 {SITE.name.toLowerCase()} &middot; feito no Brasil com Astro e opiniao demais</span>
        <span class="status">● build passing · last deploy 2026.05.29</span>
      </div>
    </div>
  </footer>
)}

{admin && (
  <footer style="border-top:1px solid var(--border);padding:32px 48px;display:flex;justify-content:space-between;gap:16px;align-items:center;font-family:var(--f-mono);font-size:11px;color:var(--fg-dim);flex-wrap:wrap">
    <span>// admin · {SITE.name.toLowerCase()} v.2026.05 · build a8f3c2d</span>
    <span>whisper-large-v3 · claude-haiku-4-5 · mock local · 8 jobs/h limit</span>
  </footer>
)}

<script>
  document.querySelectorAll('[data-menu-toggle]').forEach(function(button) {
    var nav = button.closest('nav');
    var panel = nav && nav.querySelector('[data-mobile-panel]');
    if (!panel) return;
    button.addEventListener('click', function() {
      var open = button.getAttribute('aria-expanded') !== 'true';
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.setAttribute('data-open', open ? 'true' : 'false');
    });
  });
</script>
