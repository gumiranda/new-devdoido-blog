---
import type { Badge } from '../../data/devdoido';

interface Props {
  href?: string;
  category: string;
  title: string;
  author?: string;
  date: string;
  reads?: string;
  display: string;
  badges?: Badge[];
  coverColor?: string;
}

const {
  href = '#',
  category,
  title,
  author = '@devdoido',
  date,
  reads,
  display,
  badges = [],
  coverColor = 'b',
} = Astro.props;
---

<a class="post-card" href={href}>
  <div class={`post-cover ${coverColor}`}>
    <span class="glyph">{display.slice(0, 4)}</span>
    <span class="cover-cat">{category.split('·')[0]?.replace('//', '').trim() || category}</span>
    {badges.length > 0 && (
      <span class="cover-badge">{badges[0].label}</span>
    )}
  </div>
  <div class="post-body">
    <div class="post-meta-line">
      <span>{date}</span>
      <span class="time">{category.split('·')[1]?.trim() || ''}</span>
    </div>
    <h3>{title}</h3>
    <div class="post-tags">
      {badges.map((badge) => (
        <span class="post-tag">{badge.label}</span>
      ))}
    </div>
    <div class="post-foot">
      <div class="author">
        <div class="avatar">{(author[0] || 'D').toUpperCase()}</div>
        <span class="author-name">{author}</span>
      </div>
      {reads && <span class="read-link">{reads} views</span>}
    </div>
  </div>
</a>
