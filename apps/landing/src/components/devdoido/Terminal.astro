---
interface Props {
  title?: string;
  accent?: boolean;
}

const { title = '~/devdoido', accent = false } = Astro.props;
---

<div class="term" style={accent ? 'border-color:var(--accent)' : undefined}>
  <div class="term-head">
    <span class="term-dot" style="background:#ff5f56"></span>
    <span class="term-dot" style="background:#ffbd2e"></span>
    <span class="term-dot" style="background:#27c93f"></span>
    <span style="margin-left:8px">{title}</span>
  </div>
  <div class="term-body" tabindex="0" aria-label={title}>
    <slot />
  </div>
</div>
