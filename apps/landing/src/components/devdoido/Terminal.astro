---
interface Props {
  title?: string;
  accent?: boolean;
}

const { title = '~/devdoido', accent = false } = Astro.props;
---

<div class="terminal" style={accent ? 'border-color:var(--lime-500)' : undefined}>
  <div class="bar">
    <div class="dots">
      <span style="background:#ff5f56"></span>
      <span style="background:#ffbd2e"></span>
      <span style="background:#27c93f"></span>
    </div>
    <span>{title}</span>
  </div>
  <div class="body" tabindex="0" aria-label={title}>
    <slot />
  </div>
</div>
