# ── Database (Neon serverless Postgres) ──
# Pooled connection string from your Neon project (used by the app + drizzle-kit).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Better Auth ──
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-please
BETTER_AUTH_URL=http://localhost:3000

# ── HTTP / CORS ──
PORT=3000
HOST=0.0.0.0
# Comma-separated browser origins allowed to call this API (the landing app).
CORS_ORIGIN=http://localhost:4321

# ── Google OAuth + YouTube Data API ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/google/callback

# ── Google Search Console ──
GOOGLE_SEARCH_CONSOLE_PROPERTY=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Encryption (AES-256-GCM for Google tokens at rest) ──
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=

# ── AI Article Generation (Claude) ──
ANTHROPIC_API_KEY=

# ── Content Moderation (OpenAI) ──
OPENAI_API_KEY=

# ── Transcription (Gladia) ──
GLADIA_API_KEY=
GLADIA_WEBHOOK_SECRET=

# ── Email (Resend) ──
RESEND_API_KEY=

# ── Payments ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# ── Storage (S3-compatible, e.g. Cloudflare R2) ──
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
