# ── Database (Neon serverless Postgres) ──
# Pooled connection string from your Neon project (used by the app + drizzle-kit).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# ── Better Auth ──
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET=change-me-please
BETTER_AUTH_URL=http://localhost:3000

# ── HTTP / CORS ──
PORT=3000
HOST=0.0.0.0
# Comma-separated browser origins allowed to call this API (the landing app).
CORS_ORIGIN=http://localhost:4321

# ── External integrations (STUBBED this phase — TODO) ──
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ANTHROPIC_API_KEY=        # AI article generation (Claude)
# OPENAI_API_KEY=           # moderation
# STRIPE_SECRET_KEY=        # card payments
# ABACATEPAY_API_KEY=       # Pix payments
