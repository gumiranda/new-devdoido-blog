{
  "name": "api",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "db:generate": "node ./node_modules/.bin/drizzle-kit generate",
    "db:migrate": "node ./node_modules/.bin/drizzle-kit migrate",
    "db:push": "node ./node_modules/.bin/drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts",
    "db:studio": "node ./node_modules/.bin/drizzle-kit studio",
    "auth:generate": "bunx @better-auth/cli generate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.12",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  }
}
